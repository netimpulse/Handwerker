{%- liquid
  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag
  assign heading_alignment = section.settings.heading_alignment
  assign show_heading = section.settings.show_heading
  assign subheading = section.settings.subheading
  assign layout = section.settings.layout
  assign show_dividers = section.settings.show_dividers
  assign enable_animation = section.settings.enable_animation
  assign animation_duration = section.settings.animation_duration
  assign color_scheme = section.settings.color_scheme
  assign background_image = section.settings.background_image
  assign overlay_color = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

<div
  id="shopify-section-{{ section.id }}"
  class="trust-credentials color-scheme--{{ color_scheme }}"
  style="
    --padding-top: {{ padding_top }}px;
    --padding-bottom: {{ padding_bottom }}px;
  "
>
  <div
    class="trust-credentials__background"
    {% if background_image %}
      style="--background-image: url('{{ background_image | image_url: width: 1600 }}');"
    {% endif %}
  >
    {% if background_image %}
      <div
        class="trust-credentials__overlay"
        style="
          --overlay-color: {{ overlay_color | color_modify: 'alpha', overlay_opacity }};
        "
      ></div>
    {% endif %}
  </div>

  <div class="trust-credentials__wrapper">
    {% if show_heading %}
      <div class="trust-credentials__header" style="text-align: {{ heading_alignment }};">
        <{{ heading_tag }} class="trust-credentials__heading">
          {{ heading }}
        </{{ heading_tag }}>
        {% if subheading %}
          <p class="trust-credentials__subheading">{{ subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="trust-credentials__container trust-credentials__layout--{{ layout }}" data-animation-enabled="{{ enable_animation }}" data-animation-duration="{{ animation_duration }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign block_type = block.type
          assign block_id = block.id
        -%}

        {% if block_type == 'credential' %}
          {%- liquid
            assign cred_image = block.settings.image
            assign cred_title = block.settings.title
            assign cred_subtitle = block.settings.subtitle
          -%}

          <div
            class="trust-credentials__item trust-credentials__item--credential"
            {% if show_dividers and forloop.index != forloop.length %}
              data-show-divider="true"
            {% endif %}
          >
            {% if cred_image %}
              <div class="trust-credentials__credential-image">
                <img
                  src="{{ cred_image | image_url: width: 200 }}"
                  alt="{{ cred_title | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                />
              </div>
            {% endif %}

            <div class="trust-credentials__credential-content">
              {% if cred_title %}
                <h3 class="trust-credentials__credential-title">
                  {{ cred_title }}
                </h3>
              {% endif %}
              {% if cred_subtitle %}
                <p class="trust-credentials__credential-subtitle">
                  {{ cred_subtitle }}
                </p>
              {% endif %}
            </div>
          </div>

        {% elsif block_type == 'counter' %}
          {%- liquid
            assign counter_number = block.settings.number
            assign counter_suffix = block.settings.suffix
            assign counter_label = block.settings.label
            assign counter_icon = block.settings.icon
          -%}

          <div
            class="trust-credentials__item trust-credentials__item--counter"
            data-counter-block="true"
            data-counter-value="{{ counter_number }}"
            {% if show_dividers and forloop.index != forloop.length %}
              data-show-divider="true"
            {% endif %}
          >
            {% if counter_icon %}
              <div class="trust-credentials__counter-icon">
                <img
                  src="{{ counter_icon | image_url: width: 80 }}"
                  alt=""
                  loading="lazy"
                  width="40"
                  height="40"
                  aria-hidden="true"
                />
              </div>
            {% endif %}

            <div class="trust-credentials__counter-display">
              <div class="trust-credentials__counter-number" role="status" aria-label="{{ counter_label }}">
                <span class="trust-credentials__counter-value">0</span>
                {% if counter_suffix %}
                  <span class="trust-credentials__counter-suffix">{{ counter_suffix }}</span>
                {% endif %}
              </div>
              {% if counter_label %}
                <p class="trust-credentials__counter-label">
                  {{ counter_label }}
                </p>
              {% endif %}
            </div>
          </div>

        {% endif %}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --color-foreground: rgb(var(--color-foreground));
    --color-background: rgb(var(--color-background));
    --color-accent: rgb(var(--color-accent));

    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    position: relative;
    overflow: hidden;
  }

  .trust-credentials__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: var(--background-image);
    background-size: cover;
    background-position: center;
    z-index: -2;
  }

  .trust-credentials__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--overlay-color);
    z-index: -1;
  }

  .trust-credentials__wrapper {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .trust-credentials__header {
    margin-bottom: 2rem;
  }

  .trust-credentials__heading {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 600;
    margin: 0;
    color: var(--color-foreground);
  }

  .trust-credentials__subheading {
    font-size: 1rem;
    margin: 0.5rem 0 0 0;
    color: var(--color-foreground);
    opacity: 0.85;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Container layouts */
  .trust-credentials__container {
    display: flex;
    gap: 1.5rem;
    width: 100%;
  }

  .trust-credentials__layout--bar {
    flex-direction: row;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .trust-credentials__layout--bar::-webkit-scrollbar {
    display: none;
  }

  .trust-credentials__layout--grid-3 {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
  }

  .trust-credentials__layout--grid-4 {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
  }

  .trust-credentials__layout--centered {
    flex-direction: column;
    align-items: center;
  }

  /* Item styling */
  .trust-credentials__item {
    flex-shrink: 0;
    scroll-snap-align: start;
    position: relative;
  }

  .trust-credentials__layout--bar .trust-credentials__item {
    min-width: 280px;
    max-width: 280px;
  }

  .trust-credentials__layout--grid-3 .trust-credentials__item {
    flex: 1 1 calc(33.333% - 1rem);
    min-width: 200px;
    max-width: none;
  }

  .trust-credentials__layout--grid-4 .trust-credentials__item {
    flex: 1 1 calc(25% - 1.125rem);
    min-width: 150px;
    max-width: none;
  }

  .trust-credentials__layout--centered .trust-credentials__item {
    width: 100%;
    max-width: 400px;
  }

  /* Divider styling */
  .trust-credentials__item[data-show-divider="true"]::after {
    content: '';
    position: absolute;
    right: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 60%;
    background-color: var(--color-foreground);
    opacity: 0.2;
  }

  .trust-credentials__layout--centered .trust-credentials__item[data-show-divider="true"]::after,
  .trust-credentials__layout--grid-3 .trust-credentials__item[data-show-divider="true"]::after,
  .trust-credentials__layout--grid-4 .trust-credentials__item[data-show-divider="true"]::after {
    display: none;
  }

  /* Credential styling */
  .trust-credentials__item--credential {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .trust-credentials__credential-image {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100px;
  }

  .trust-credentials__credential-image img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .trust-credentials__credential-title {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .trust-credentials__credential-subtitle {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-foreground);
    opacity: 0.8;
    line-height: 1.5;
  }

  /* Counter styling */
  .trust-credentials__item--counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .trust-credentials__counter-icon {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .trust-credentials__counter-icon img {
    max-width: 100%;
    height: auto;
  }

  .trust-credentials__counter-number {
    font-size: clamp(1.75rem, 6vw, 2.5rem);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.25rem;
    justify-content: center;
    align-items: baseline;
  }

  .trust-credentials__counter-value {
    display: inline-block;
  }

  .trust-credentials__counter-suffix {
    font-size: 0.8em;
    opacity: 0.9;
  }

  .trust-credentials__counter-label {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-foreground);
    opacity: 0.85;
    font-weight: 500;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .trust-credentials__wrapper {
      padding: 0 1rem;
    }

    .trust-credentials__header {
      margin-bottom: 1.5rem;
    }

    .trust-credentials__container {
      gap: 1rem;
    }

    .trust-credentials__layout--grid-3 .trust-credentials__item {
      flex: 1 1 calc(50% - 0.5rem);
    }

    .trust-credentials__layout--grid-4 .trust-credentials__item {
      flex: 1 1 calc(50% - 0.5rem);
    }

    .trust-credentials__layout--bar .trust-credentials__item {
      min-width: 240px;
      max-width: 240px;
    }
  }

  @media (max-width: 480px) {
    .trust-credentials__layout--bar .trust-credentials__item,
    .trust-credentials__layout--grid-3 .trust-credentials__item,
    .trust-credentials__layout--grid-4 .trust-credentials__item {
      flex: 1 1 100%;
      min-width: unset;
    }

    .trust-credentials__container {
      gap: 1.5rem;
    }

    .trust-credentials__item[data-show-divider="true"]::after {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script type="module">
  class TrustCredentialsSection extends HTMLElement {
    connectedCallback() {
      this.animationEnabled = this.dataset.animationEnabled === 'true';
      this.animationDuration = parseInt(this.dataset.animationDuration) || 1500;
      this.container = this.querySelector('[data-animation-enabled]');
      this.prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (this.animationEnabled && !this.prefersReducedMotion) {
        this.setupCounterAnimation();
      } else if (!this.prefersReducedMotion) {
        this.displayFinalNumbers();
      }

      // Theme Editor support
      if (window.Shopify?.designMode) {
        this.setupThemeEditorListeners();
      }
    }

    setupCounterAnimation() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !entry.target.dataset.animated) {
            entry.target.dataset.animated = 'true';
            this.animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });

      this.querySelectorAll('[data-counter-block="true"]').forEach((counterBlock) => {
        observer.observe(counterBlock);
      });
    }

    animateCounter(element) {
      const targetValue = parseFloat(element.dataset.counterValue);
      const valueDisplay = element.querySelector('.trust-credentials__counter-value');
      const isDecimal = !Number.isInteger(targetValue);
      const decimalPlaces = isDecimal ? targetValue.toString().split('.')[1].length : 0;

      let currentValue = 0;
      const startTime = performance.now();

      const animate = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / this.animationDuration, 1);

        if (isDecimal) {
          currentValue = (targetValue * progress).toFixed(decimalPlaces);
        } else {
          currentValue = Math.floor(targetValue * progress);
        }

        valueDisplay.textContent = this.formatNumber(currentValue);

        if (progress < 1) {
          requestAnimationFrame(animate);
        } else {
          valueDisplay.textContent = this.formatNumber(targetValue);
        }
      };

      requestAnimationFrame(animate);
    }

    displayFinalNumbers() {
      this.querySelectorAll('[data-counter-block="true"]').forEach((counterBlock) => {
        const targetValue = parseFloat(counterBlock.dataset.counterValue);
        const valueDisplay = counterBlock.querySelector('.trust-credentials__counter-value');
        valueDisplay.textContent = this.formatNumber(targetValue);
      });
    }

    formatNumber(value) {
      if (typeof value === 'string') {
        value = parseFloat(value);
      }

      if (value >= 1000000) {
        return (value / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
      } else if (value >= 1000) {
        return (value / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
      }
      return Math.round(value).toString();
    }

    setupThemeEditorListeners() {
      document.addEventListener('shopify:section:load', (e) => {
        if (e.detail.sectionId === this.id.replace('shopify-section-', '')) {
          this.connectedCallback();
        }
      });
    }
  }

  if (!customElements.get('trust-credentials-section')) {
    customElements.define('trust-credentials-section', TrustCredentialsSection);
  }
</script>

{% schema %}
{
  "name": "Trust & Credentials",
  "description": "Display certifications, credentials, and achievement statistics",
  "class": "trust-credentials-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Trust Us"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Industry-leading expertise and recognition"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "bar", "label": "Horizontal scrolling bar" },
        { "value": "grid-3", "label": "Grid (3 columns)" },
        { "value": "grid-4", "label": "Grid (4 columns)" },
        { "value": "centered", "label": "Centered stack" }
      ],
      "default": "grid-3"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Show dividers between items",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable counter animation",
      "default": true
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Counter animation duration (ms)",
      "min": 1000,
      "max": 3000,
      "step": 100,
      "default": 1500,
      "unit": "ms"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.2
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon or logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Certified Professional"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Description",
          "default": "Industry certification details"
        }
      ]
    },
    {
      "type": "counter",
      "name": "Counter",
      "settings": [
        {
          "type": "number",
          "id": "number",
          "label": "Number",
          "default": 500
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (e.g., %, +, years)",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Projects Completed"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust & Credentials",
      "blocks": [
        {
          "type": "credential",
          "settings": {
            "title": "Licensed & Insured",
            "subtitle": "Full coverage for peace of mind"
          }
        },
        {
          "type": "credential",
          "settings": {
            "title": "EPA Certified",
            "subtitle": "Environmental standards met"
          }
        },
        {
          "type": "counter",
          "settings": {
            "number": 15,
            "suffix": "years",
            "label": "Experience"
          }
        }
      ]
    }
  ]
}
{% endschema %}
