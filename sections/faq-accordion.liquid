{% comment %}
  Craftsman FAQ Accordion Section
  Features: Animated accordion, category filtering, live search, smooth transitions
  Color scheme integrated, Web Component wrapper, Dawn CSS variables
{% endcomment %}

{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
-%}

<faq-accordion-craftsman
  class="color-{{ section.settings.color_scheme }}"
  style="--h-font: {{ h_font }}; --h-size: {{ h_size }}px; --h-color: {{ h_color }}; --h-weight: {{ h_weight }}; --max-width: {{ section.settings.max_width }}px; --margin-top: {{ section.settings.margin_top }}px; --margin-bottom: {{ section.settings.margin_bottom }}px; --padding-horizontal: {{ section.settings.padding_horizontal }}px; --text-alignment: {{ section.settings.text_alignment }}; --title-size: {{ section.settings.title_size }}px; --description-font: inherit; --description-size: {{ section.settings.description_size | default: 16 }}px; --description-color: rgb(var(--color-foreground));"
>
  <div class="faq-header">
    {%- if show_label and label_text != blank -%}
      <span class="section-label">{{ label_text }}</span>
    {%- endif -%}
    <h2 class="faq-title">{{ section.settings.title }}</h2>
    {% if section.settings.subtitle %}
      <p class="faq-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="faq-controls">
      <div class="faq-filters">
        <button class="filter-btn active" data-filter="all" aria-label="Show all questions">All Questions</button>
        {% assign categories = '' %}
        {% for block in section.blocks %}
          {% assign category = block.settings.category %}
          {% unless categories contains category %}
            {% assign categories = categories | append: ',' | append: category %}
            <button class="filter-btn" data-filter="{{ category | downcase | replace: ' ', '-' }}" aria-label="Filter by {{ category }}">
              {{ category }}
            </button>
          {% endunless %}
        {% endfor %}
      </div>

      <div class="faq-search-wrapper">
        <input
          type="text"
          class="faq-search-input"
          placeholder="Search questions..."
          aria-label="Search FAQ questions"
        >
        <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"/>
          <path d="M14 14l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <div class="faq-counter">
      <span class="counter-text">Showing <strong class="counter-visible">{{ section.blocks.size }}</strong> of <strong class="counter-total">{{ section.blocks.size }}</strong> questions</span>
    </div>

    <div class="accordion" role="region" aria-label="FAQ Accordion">
      {% for block in section.blocks %}
        <div
          class="accordion-item"
          data-category="{{ block.settings.category | downcase | replace: ' ', '-' }}"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          <button
            class="accordion-header"
            aria-expanded="false"
            aria-controls="panel-{{ forloop.index0 }}"
            id="button-{{ forloop.index0 }}"
          >
            <span class="accordion-title">{{ block.settings.question }}</span>
            <div class="accordion-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </div>
          </button>

          <div
            class="accordion-panel"
            id="panel-{{ forloop.index0 }}"
            role="region"
            aria-labelledby="button-{{ forloop.index0 }}"
            hidden
          >
            <div class="accordion-content">
              <div class="accordion-left-border" aria-hidden="true"></div>
              <div class="accordion-text">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  {% else %}
    <div class="faq-placeholder">
      <p>Add FAQ items to your accordion to get started.</p>
    </div>
  {% endif %}
</faq-accordion-craftsman>

<style>
  #shopify-section-{{ section.id }} {
    --duration-fast: 0.3s;
    --duration-normal: 0.4s;
    --easing-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --border-radius: 8px;
    --border-radius-pill: 20px;
  }

  #shopify-section-{{ section.id }} .section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgb(var(--color-button));
    background: rgba(var(--color-button), 0.1);
    padding: 4px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} faq-accordion-craftsman {
    display: block;
    max-width: var(--max-width);
    margin: var(--margin-top) auto var(--margin-bottom);
    padding: {{ section.settings.padding_top }}px var(--padding-horizontal) var(--padding-horizontal) var(--padding-horizontal);
    background-color: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .faq-header {
    text-align: var(--text-alignment);
    margin-bottom: 40px;
  }

  #shopify-section-{{ section.id }} .faq-title {
    font-family: var(--h-font);
    font-size: var(--h-size);
    font-weight: var(--h-weight);
    color: var(--h-color);
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  #shopify-section-{{ section.id }} .faq-subtitle {
    font-family: inherit;
    font-size: var(--description-size);
    color: var(--description-color);
    margin: 0;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .faq-controls {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 30px;
    padding: 24px;
    background: rgba(var(--color-foreground), 0.05);
    border-radius: var(--border-radius);
    border: 1px solid rgba(var(--color-border), 0.5);
  }

  #shopify-section-{{ section.id }} .faq-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .filter-btn {
    padding: 10px 20px;
    border: 2px solid transparent;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--border-radius-pill);
    cursor: pointer;
    transition: all var(--duration-fast) var(--easing-spring);
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .filter-btn:hover {
    border-color: rgb(var(--color-button));
    transform: translateY(-2px);
    background: rgba(var(--color-button), 0.05);
  }

  #shopify-section-{{ section.id }} .filter-btn.active {
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border-color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .faq-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .faq-search-input {
    width: 100%;
    padding: 12px 16px 12px 40px;
    border: 2px solid rgb(var(--color-border));
    background: rgb(var(--color-background));
    border-radius: var(--border-radius);
    font-family: inherit;
    font-size: 14px;
    color: rgb(var(--color-foreground));
    transition: all var(--duration-fast) ease;
    overflow-wrap: break-word;
  }

  #shopify-section-{{ section.id }} .faq-search-input::placeholder {
    color: rgba(var(--color-foreground), 0.5);
  }

  #shopify-section-{{ section.id }} .faq-search-input:focus {
    outline: none;
    border-color: rgb(var(--color-button));
    box-shadow: 0 0 0 3px rgba(var(--color-button), 0.1);
  }

  #shopify-section-{{ section.id }} .search-icon {
    position: absolute;
    left: 12px;
    color: rgba(var(--color-foreground), 0.5);
    pointer-events: none;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .faq-counter {
    text-align: center;
    margin-bottom: 20px;
  }

  #shopify-section-{{ section.id }} .counter-text {
    font-family: inherit;
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.7);
  }

  #shopify-section-{{ section.id }} .counter-visible,
  #shopify-section-{{ section.id }} .counter-total {
    color: rgb(var(--color-button));
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .accordion {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .accordion-item {
    border-radius: var(--border-radius);
    background: rgb(var(--color-background));
    border: 1px solid rgb(var(--color-border));
    overflow: hidden;
    transition: all var(--duration-fast) ease;
  }

  #shopify-section-{{ section.id }} .accordion-item:hover {
    border-color: rgb(var(--color-button));
    box-shadow: 0 4px 12px rgba(var(--color-foreground), 0.08);
  }

  #shopify-section-{{ section.id }} .accordion-item.active {
    border-color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .accordion-header {
    width: 100%;
    padding: 20px 24px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    transition: all var(--duration-fast) ease;
    text-align: left;
  }

  #shopify-section-{{ section.id }} .accordion-header:focus-visible {
    outline: 2px solid rgb(var(--color-button));
    outline-offset: 2px;
  }

  #shopify-section-{{ section.id }} .accordion-item.active .accordion-header {
    background: rgba(var(--color-button), 0.05);
  }

  #shopify-section-{{ section.id }} .accordion-title {
    flex: 1;
    line-height: 1.4;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .accordion-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--duration-normal) var(--easing-spring);
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .accordion-item.active .accordion-icon {
    transform: rotate(180deg);
  }

  #shopify-section-{{ section.id }} .accordion-panel {
    overflow: hidden;
    transition: max-height var(--duration-normal) var(--easing-spring),
                opacity var(--duration-fast) ease;
    max-height: 0;
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .accordion-panel:not([hidden]) {
    max-height: 1000px;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .accordion-content {
    padding: 0 24px 24px 24px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .accordion-left-border {
    width: 4px;
    background: linear-gradient(180deg, rgb(var(--color-button)) 0%, rgba(var(--color-button), 0.7) 100%);
    border-radius: 2px;
    flex-shrink: 0;
    min-height: 20px;
  }

  #shopify-section-{{ section.id }} .accordion-text {
    font-family: inherit;
    font-size: 14px;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.8;
    flex: 1;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .accordion-text p {
    margin: 0 0 12px 0;
  }

  #shopify-section-{{ section.id }} .accordion-text p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .faq-placeholder {
    text-align: center;
    padding: 60px 20px;
    color: rgba(var(--color-foreground), 0.5);
    font-family: inherit;
    font-size: 15px;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .accordion-item.hidden {
    display: none;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} faq-accordion-craftsman {
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .faq-header {
      margin-bottom: 30px;
    }

    #shopify-section-{{ section.id }} .faq-title {
      font-size: 28px;
    }

    #shopify-section-{{ section.id }} .faq-subtitle {
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .faq-controls {
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .faq-filters {
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .filter-btn {
      padding: 8px 12px;
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .accordion-header {
      padding: 18px 20px;
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .accordion-content {
      padding: 0 20px 20px 20px;
    }

    #shopify-section-{{ section.id }} .accordion-text {
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    #shopify-section-{{ section.id }} faq-accordion-craftsman {
      padding: 16px;
    }

    #shopify-section-{{ section.id }} .faq-title {
      font-size: 24px;
    }

    #shopify-section-{{ section.id }} .faq-controls {
      flex-direction: column;
      padding: 16px;
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .faq-filters {
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .filter-btn {
      padding: 8px 14px;
      font-size: 12px;
      flex: 0 1 auto;
    }

    #shopify-section-{{ section.id }} .accordion-header {
      padding: 16px;
      font-size: 14px;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .accordion-content {
      padding: 0 16px 16px 16px;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .accordion-left-border {
      width: 3px;
      min-height: 16px;
    }

    #shopify-section-{{ section.id }} .accordion-text {
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .faq-search-input {
      padding: 10px 14px 10px 36px;
      font-size: 13px;
    }
  }
</style>

<script>
  class FaqAccordionCraftsman extends HTMLElement {
    connectedCallback() {
      this.init();
    }

    init() {
      const container = this;
      const accordion = container.querySelector('.accordion');
      const items = container.querySelectorAll('.accordion-item');
      const filterBtns = container.querySelectorAll('.filter-btn');
      const searchInput = container.querySelector('.faq-search-input');
      const counterVisible = container.querySelector('.counter-visible');
      const counterTotal = container.querySelector('.counter-total');

      if (!items.length) return;

      let currentFilter = 'all';
      let currentSearch = '';
      let visibleIndices = [];

      // Accordion Toggle
      items.forEach((item) => {
        const header = item.querySelector('.accordion-header');
        const panel = item.querySelector('.accordion-panel');

        header.addEventListener('click', () => {
          this.toggleAccordionItem(item, header, panel);
        });
      });

      // Filter Function
      const applyFilters = () => {
        let visibleCount = 0;
        visibleIndices = [];

        items.forEach((item, index) => {
          const category = item.getAttribute('data-category');
          const question = item.querySelector('.accordion-title').textContent.toLowerCase();

          const matchesCategory = currentFilter === 'all' || category === currentFilter;
          const matchesSearch = currentSearch === '' || question.includes(currentSearch.toLowerCase());
          const shouldShow = matchesCategory && matchesSearch;

          if (shouldShow) {
            item.classList.remove('hidden');
            visibleCount++;
            visibleIndices.push(index);
          } else {
            item.classList.add('hidden');
            item.classList.remove('active');
            item.querySelector('.accordion-panel').setAttribute('hidden', '');
            item.querySelector('.accordion-header').setAttribute('aria-expanded', 'false');
          }
        });

        if (counterVisible && counterTotal) {
          counterVisible.textContent = visibleCount;
          counterTotal.textContent = items.length;
        }
      };

      // Filter Button Clicks
      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentFilter = btn.getAttribute('data-filter');
          currentSearch = '';
          if (searchInput) searchInput.value = '';
          applyFilters();
        });
      });

      // Search Input
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          currentSearch = e.target.value;
          applyFilters();
        });
      }

      // Keyboard Navigation
      items.forEach((item, index) => {
        const header = item.querySelector('.accordion-header');

        header.addEventListener('keydown', (e) => {
          let targetIndex = -1;

          switch (e.key) {
            case 'ArrowDown':
              e.preventDefault();
              targetIndex = visibleIndices.indexOf(index) + 1;
              if (targetIndex < visibleIndices.length) {
                items[visibleIndices[targetIndex]].querySelector('.accordion-header').focus();
              }
              break;
            case 'ArrowUp':
              e.preventDefault();
              targetIndex = visibleIndices.indexOf(index) - 1;
              if (targetIndex >= 0) {
                items[visibleIndices[targetIndex]].querySelector('.accordion-header').focus();
              }
              break;
            case 'Home':
              e.preventDefault();
              if (visibleIndices.length > 0) {
                items[visibleIndices[0]].querySelector('.accordion-header').focus();
              }
              break;
            case 'End':
              e.preventDefault();
              if (visibleIndices.length > 0) {
                items[visibleIndices[visibleIndices.length - 1]].querySelector('.accordion-header').focus();
              }
              break;
          }
        });
      });

      // Initialize
      applyFilters();
    }

    toggleAccordionItem(item, header, panel) {
      const isActive = item.classList.contains('active');

      if (isActive) {
        item.classList.remove('active');
        header.setAttribute('aria-expanded', 'false');
        panel.setAttribute('hidden', '');
      } else {
        item.classList.add('active');
        header.setAttribute('aria-expanded', 'true');
        panel.removeAttribute('hidden');
      }
    }
  }

  customElements.define('faq-accordion-craftsman', FaqAccordionCraftsman);
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "FAQ"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Find answers to common questions about our craftsman services"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "system-ui, sans-serif", "label": "System" },
        { "value": "inherit", "label": "Inherit" },
        { "value": "Georgia, serif", "label": "Georgia" }
      ],
      "default": "system-ui, sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size (px)",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal Padding (px)",
      "min": 0,
      "max": 60,
      "step": 10,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top Margin (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom Margin (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
