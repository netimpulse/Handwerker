{% comment %}
  FAQ Accordion Section
  Professional Q&A section with smooth animations, keyboard navigation, and optional search
{% endcomment %}

<section id="shopify-section-{{ section.id }}" class="faq-accordion color-scheme--{{ section.settings.color_scheme }}">
  <div class="faq-accordion__container">
    {% comment %} Section Heading {% endcomment %}
    {% if section.settings.heading != blank %}
      <div class="faq-accordion__header">
        {% assign heading_tag = section.settings.heading_tag | default: 'h2' %}
        <{{ heading_tag }} class="faq-accordion__title">{{ section.settings.heading }}</{{ heading_tag }}>

        {% if section.settings.subheading != blank %}
          <div class="faq-accordion__subheading">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% comment %} Optional Search Box {% endcomment %}
    {% if section.settings.enable_search %}
      <div class="faq-accordion__search-wrapper">
        <input
          type="text"
          class="faq-accordion__search-input"
          placeholder="{{ 'sections.faq_accordion.search_placeholder' | t: _locale: 'en' | default: 'Search FAQs...' }}"
          aria-label="Search FAQ items"
        >
        <svg class="faq-accordion__search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </div>
    {% endif %}

    {% comment %} Category Filter (if enabled and categories exist) {% endcomment %}
    {% if section.settings.enable_categories %}
      {% assign categories = '' %}
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category != blank %}
          {% unless categories contains block.settings.category %}
            {% assign categories = categories | append: block.settings.category | append: '|' %}
          {% endunless %}
        {% endif %}
      {% endfor %}

      {% if categories != blank %}
        <div class="faq-accordion__categories">
          <button class="faq-accordion__category-btn faq-accordion__category-btn--active" data-category="all">
            {{ 'sections.faq_accordion.all_categories' | t: _locale: 'en' | default: 'All' }}
          </button>
          {% assign category_array = categories | split: '|' %}
          {% for category in category_array %}
            {% if category != blank %}
              <button class="faq-accordion__category-btn" data-category="{{ category | downcase | replace: ' ', '-' }}">
                {{ category }}
              </button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}

    {% comment %} FAQ Items Container {% endcomment %}
    <div class="faq-accordion__items" data-accordion-behavior="{{ section.settings.accordion_behavior }}">
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          {% assign category_attr = block.settings.category | downcase | replace: ' ', '-' %}
          <faq-accordion-item
            class="faq-accordion__item"
            data-block-id="{{ block.id }}"
            data-category="{{ category_attr }}"
            {% if forloop.first and section.settings.open_first %}open{% endif %}
          >
            <button
              class="faq-accordion__question"
              aria-expanded="{% if forloop.first and section.settings.open_first %}true{% else %}false{% endif %}"
            >
              {% if block.settings.icon != blank %}
                <span class="faq-accordion__icon-wrapper">
                  <img
                    src="{{ block.settings.icon | image_url: width: 24 }}"
                    alt=""
                    class="faq-accordion__icon"
                    loading="lazy"
                    width="24"
                    height="24"
                  >
                </span>
              {% elsif section.settings.icon_style != 'none' %}
                <span class="faq-accordion__icon faq-accordion__icon--{{ section.settings.icon_style }}"></span>
              {% endif %}

              <span class="faq-accordion__question-text">{{ block.settings.question }}</span>
            </button>

            <div class="faq-accordion__answer-wrapper">
              <div class="faq-accordion__answer">
                {{ block.settings.answer }}
              </div>
            </div>
          </faq-accordion-item>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <div class="faq-accordion__placeholder">
          <p>{{ 'sections.faq_accordion.no_items' | t: _locale: 'en' | default: 'Add FAQ items to get started' }}</p>
        </div>
      {% endif %}
    </div>

    {% comment %} Contact CTA Section {% endcomment %}
    {% if section.settings.show_contact_cta %}
      <div class="faq-accordion__cta">
        <p class="faq-accordion__cta-text">{{ section.settings.contact_cta_text }}</p>
        {% if section.settings.contact_cta_link != blank %}
          <a href="{{ section.settings.contact_cta_link }}" class="faq-accordion__cta-link button button--primary">
            {{ section.settings.contact_cta_button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<style>
#shopify-section-{{ section.id }} {
  --faq-text-color: var(--color-base-text);
  --faq-bg-color: var(--color-base-background);
  --faq-border-color: var(--color-border);
  --faq-hover-bg: var(--color-base-hover);
  --faq-accent: var(--color-primary);
}

#shopify-section-{{ section.id }}[data-color-scheme="accent-1"] {
  --faq-bg-color: var(--color-accent-1-background);
  --faq-text-color: var(--color-accent-1-text);
  --faq-border-color: var(--color-accent-1-border);
}

#shopify-section-{{ section.id }}[data-color-scheme="accent-2"] {
  --faq-bg-color: var(--color-accent-2-background);
  --faq-text-color: var(--color-accent-2-text);
  --faq-border-color: var(--color-accent-2-border);
}

.faq-accordion {
  background-color: var(--faq-bg-color);
  color: var(--faq-text-color);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
}

.faq-accordion__container {
  max-width: 100%;
  margin: 0 auto;
  padding: 0 1.5rem;
}

@media (min-width: 750px) {
  .faq-accordion__container {
    padding: 0 2rem;
  }
}

.faq-accordion__header {
  text-align: {{ section.settings.heading_alignment }};
  margin-bottom: 2rem;
}

.faq-accordion__title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  margin: 0 0 0.5rem 0;
  line-height: 1.2;
}

.faq-accordion__subheading {
  font-size: 1.125rem;
  font-weight: 400;
  opacity: 0.85;
  line-height: 1.6;
}

{% comment %} Search Box Styles {% endcomment %}
.faq-accordion__search-wrapper {
  position: relative;
  margin-bottom: 2rem;
  max-width: 400px;
}

.faq-accordion__search-input {
  width: 100%;
  padding: 0.75rem 2.5rem 0.75rem 1rem;
  border: 1px solid var(--faq-border-color);
  border-radius: 0.375rem;
  font-size: 1rem;
  font-family: inherit;
  background-color: var(--faq-bg-color);
  color: var(--faq-text-color);
  transition: border-color 0.2s ease;
}

.faq-accordion__search-input:focus {
  outline: none;
  border-color: var(--faq-accent);
  box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.1);
}

.faq-accordion__search-icon {
  position: absolute;
  right: 0.75rem;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  opacity: 0.6;
}

{% comment %} Category Filter Styles {% endcomment %}
.faq-accordion__categories {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 2rem;
}

.faq-accordion__category-btn {
  padding: 0.5rem 1rem;
  border: 1px solid var(--faq-border-color);
  border-radius: 0.375rem;
  background-color: transparent;
  color: var(--faq-text-color);
  font-size: 0.9375rem;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.2s ease;
}

.faq-accordion__category-btn:hover {
  background-color: var(--faq-hover-bg);
  border-color: var(--faq-accent);
}

.faq-accordion__category-btn--active {
  background-color: var(--faq-accent);
  color: var(--color-inverse-text);
  border-color: var(--faq-accent);
}

{% comment %} FAQ Items Container {% endcomment %}
.faq-accordion__items {
  max-width: 100%;
}

{% comment %} FAQ Item Styles {% endcomment %}
.faq-accordion__item {
  display: block;
  margin-bottom: {% if section.settings.border_style != 'none' %}1px{% else %}0{% endif %};
  transition: background-color 0.2s ease;
}

{% if section.settings.border_style == 'full-border' %}
  .faq-accordion__item {
    border: 1px solid var(--faq-border-color);
    border-radius: {{ section.settings.corner_radius }}px;
    margin-bottom: 1rem;
  }

  .faq-accordion__item + .faq-accordion__item {
    margin-bottom: 1rem;
  }
{% elsif section.settings.border_style == 'bottom-only' %}
  .faq-accordion__item {
    border-bottom: 1px solid var(--faq-border-color);
    padding: 1rem 0;
  }

  .faq-accordion__item:last-child {
    border-bottom: none;
  }
{% endif %}

.faq-accordion__question {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem;
  background-color: transparent;
  color: var(--faq-text-color);
  border: none;
  font-size: 1.0625rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  text-align: left;
  transition: background-color 0.2s ease;
}

.faq-accordion__question:hover {
  background-color: var(--faq-hover-bg);
}

.faq-accordion__question:focus {
  outline: 2px solid var(--faq-accent);
  outline-offset: 2px;
}

.faq-accordion__question-text {
  flex: 1;
  line-height: 1.4;
}

{% comment %} Icon Styles {% endcomment %}
.faq-accordion__icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.faq-accordion__icon {
  width: 24px;
  height: 24px;
  display: block;
}

.faq-accordion__icon--plus-minus::before,
.faq-accordion__icon--plus-minus::after {
  content: '';
  display: block;
  position: absolute;
  background-color: var(--faq-accent);
  transition: all 0.3s ease;
}

.faq-accordion__item[open] .faq-accordion__question::before {
  transform: scaleX(0);
}

{% comment %} Chevron Icon {% endcomment %}
.faq-accordion__icon--chevron::after {
  content: '';
  display: inline-block;
  width: 0.5rem;
  height: 0.5rem;
  border-right: 2px solid var(--faq-accent);
  border-bottom: 2px solid var(--faq-accent);
  transform: rotate(45deg) translateY(-2px);
  transition: transform 0.3s ease;
  margin-left: auto;
  flex-shrink: 0;
}

.faq-accordion__item[open] .faq-accordion__question .faq-accordion__icon--chevron::after {
  transform: rotate(225deg) translateY(2px);
}

{% comment %} Arrow Icon {% endcomment %}
.faq-accordion__icon--arrow::after {
  content: '';
  display: inline-block;
  width: 2px;
  height: 0.75rem;
  background-color: var(--faq-accent);
  transform: rotate(45deg);
  transition: transform 0.3s ease;
  margin-left: auto;
  flex-shrink: 0;
}

.faq-accordion__item[open] .faq-accordion__question .faq-accordion__icon--arrow::after {
  transform: rotate(225deg);
}

{% comment %} Answer Animation Wrapper {% endcomment %}
.faq-accordion__answer-wrapper {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
}

@media (prefers-reduced-motion: reduce) {
  .faq-accordion__answer-wrapper {
    transition: none;
  }
}

.faq-accordion__item[open] .faq-accordion__answer-wrapper {
  max-height: 2000px;
}

.faq-accordion__answer {
  padding: 0 1.25rem 1.25rem 1.25rem;
  font-size: 1rem;
  line-height: 1.6;
  word-break: break-word;
}

{% comment %} Placeholder and Empty State {% endcomment %}
.faq-accordion__placeholder {
  padding: 3rem 1.5rem;
  text-align: center;
  color: var(--color-base-text);
  opacity: 0.6;
}

{% comment %} CTA Section {% endcomment %}
.faq-accordion__cta {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--faq-border-color);
  text-align: center;
}

.faq-accordion__cta-text {
  font-size: 1rem;
  margin: 0 0 1rem 0;
  line-height: 1.6;
}

.faq-accordion__cta-link {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  background-color: var(--faq-accent);
  color: var(--color-inverse-text);
  border-radius: 0.375rem;
  text-decoration: none;
  font-weight: 600;
  transition: opacity 0.2s ease;
}

.faq-accordion__cta-link:hover {
  opacity: 0.85;
}

.faq-accordion__cta-link:focus {
  outline: 2px solid var(--faq-accent);
  outline-offset: 2px;
}

{% comment %} Two-Column Layout {% endcomment %}
{% if section.settings.layout == 'two-column' %}
  @media (min-width: 750px) {
    .faq-accordion__container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: start;
    }

    .faq-accordion__header {
      grid-column: 1 / -1;
      text-align: left;
    }

    .faq-accordion__search-wrapper {
      grid-column: 1 / -1;
    }

    .faq-accordion__categories {
      grid-column: 1 / -1;
    }

    .faq-accordion__items {
      grid-column: 1;
    }

    .faq-accordion__side-image {
      grid-column: 2;
      grid-row: 3 / span 2;
      position: sticky;
      top: 1rem;
    }

    .faq-accordion__cta {
      grid-column: 1 / -1;
    }
  }
{% endif %}

.faq-accordion__side-image {
  width: 100%;
  height: auto;
  border-radius: {{ section.settings.corner_radius }}px;
  object-fit: cover;
  display: block;
}

{% comment %} Hidden Items (Search/Filter) {% endcomment %}
.faq-accordion__item.faq-accordion__item--hidden {
  display: none;
}

{% comment %} Responsive Text {% endcomment %}
@media (max-width: 749px) {
  .faq-accordion__question {
    padding: 1rem;
    font-size: 1rem;
  }

  .faq-accordion__answer {
    padding: 0 1rem 1rem 1rem;
  }
}
</style>

<script>
class FaqAccordionItem extends HTMLElement {
  connectedCallback() {
    this.button = this.querySelector('.faq-accordion__question');
    this.wrapper = this.querySelector('.faq-accordion__answer-wrapper');

    if (this.button) {
      this.button.addEventListener('click', () => this.toggle());
      this.button.addEventListener('keydown', (e) => this.handleKeydown(e));
    }
  }

  toggle() {
    const isOpen = this.hasAttribute('open');
    const container = this.closest('.faq-accordion__items');
    const behavior = container?.dataset.accordionBehavior || 'single';

    if (behavior === 'single' && !isOpen) {
      const siblings = container.querySelectorAll('faq-accordion-item[open]');
      siblings.forEach(item => {
        if (item !== this) {
          item.removeAttribute('open');
          if (item.button) {
            item.button.setAttribute('aria-expanded', 'false');
          }
        }
      });
    }

    if (isOpen) {
      this.removeAttribute('open');
      this.button.setAttribute('aria-expanded', 'false');
    } else {
      this.setAttribute('open', '');
      this.button.setAttribute('aria-expanded', 'true');
    }
  }

  handleKeydown(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      this.toggle();
    }
  }
}

class FaqAccordion extends HTMLElement {
  connectedCallback() {
    this.itemsContainer = this.querySelector('.faq-accordion__items');
    this.searchInput = this.querySelector('.faq-accordion__search-input');
    this.categoryBtns = this.querySelectorAll('.faq-accordion__category-btn');
    this.items = this.querySelectorAll('faq-accordion-item');

    if (this.searchInput) {
      this.searchInput.addEventListener('input', () => this.filterItems());
    }

    this.categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => this.filterByCategory(btn));
    });

    customElements.define('faq-accordion-item', FaqAccordionItem);
  }

  filterItems() {
    const query = this.searchInput.value.toLowerCase().trim();

    this.items.forEach(item => {
      const question = item.querySelector('.faq-accordion__question-text')?.textContent.toLowerCase() || '';
      const answer = item.querySelector('.faq-accordion__answer')?.textContent.toLowerCase() || '';

      const matches = question.includes(query) || answer.includes(query);
      item.classList.toggle('faq-accordion__item--hidden', query && !matches);
    });
  }

  filterByCategory(btn) {
    const category = btn.dataset.category;

    this.categoryBtns.forEach(b => {
      b.classList.toggle('faq-accordion__category-btn--active', b === btn);
    });

    this.items.forEach(item => {
      const itemCategory = item.dataset.category;
      const matches = category === 'all' || itemCategory === category;
      item.classList.toggle('faq-accordion__item--hidden', !matches);
    });
  }
}

customElements.define('faq-accordion', FaqAccordion);

document.addEventListener('shopify:section:load', () => {
  const faqs = document.querySelectorAll('faq-accordion');
  faqs.forEach(faq => {
    if (!customElements.get('faq-accordion')) {
      customElements.define('faq-accordion', FaqAccordion);
    }
  });
});
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "class": "shopify-section--faq-accordion",
  "tag": "section",
  "attribute": "data-section-type",
  "templates": ["index", "page", "product"],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "limit": 20,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a 30-day money-back guarantee on all products.</p>"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category (Optional)",
          "default": "Allgemein"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom Icon (Optional)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML Tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Find answers to common questions about our services</p>"
    },
    {
      "type": "select",
      "id": "accordion_behavior",
      "label": "Accordion Behavior",
      "options": [
        {
          "value": "single",
          "label": "Only One Open at a Time"
        },
        {
          "value": "multiple",
          "label": "Multiple Can Be Open"
        }
      ],
      "default": "single"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open First Item by Default",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon Style",
      "options": [
        {
          "value": "plus-minus",
          "label": "Plus/Minus"
        },
        {
          "value": "chevron",
          "label": "Chevron"
        },
        {
          "value": "arrow",
          "label": "Arrow"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "chevron"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "options": [
        {
          "value": "full-border",
          "label": "Full Border"
        },
        {
          "value": "bottom-only",
          "label": "Bottom Border Only"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "full-border"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner Radius (px)",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "enable_search",
      "label": "Enable Search/Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_categories",
      "label": "Enable Category Filtering",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_contact_cta",
      "label": "Show Contact CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_cta_text",
      "label": "Contact CTA Text",
      "default": "Still have questions? We're here to help."
    },
    {
      "type": "text",
      "id": "contact_cta_button_text",
      "label": "Contact CTA Button Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_cta_link",
      "label": "Contact CTA Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "two-column",
          "label": "Two Column with Image"
        }
      ],
      "default": "standard"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side Image (for Two-Column Layout)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
