<!-- Craftsman Sticky Header Section -->
<header-craftsman>
<header
  data-section-id="{{ section.id }}"
  class="header-craftsman color-{{ section.settings.color_scheme }}"
  data-sticky="{{ section.settings.sticky_mode }}"
  data-transparent="{{ section.settings.transparent_mode }}"
  role="banner"
>
  <!-- Top Bar -->
  {% if section.settings.topbar_show %}
    <div class="header-craftsman__topbar" style="--topbar-bg: {{ section.settings.topbar_bg | default: 'rgb(var(--color-background))' }};">
      <div class="header-craftsman__topbar-content">
        <!-- Left side: Emergency badge + Operating hours -->
        <div class="header-craftsman__topbar-left">
          {% if section.settings.emergency_badge_show %}
            <span class="header-craftsman__emergency-badge" aria-label="Emergency/Notdienst service available">
              {{ section.settings.emergency_badge_text }}
            </span>
          {% endif %}

          {% if section.settings.operating_hours %}
            <span class="header-craftsman__hours" role="status">
              {{ section.settings.operating_hours }}
            </span>
          {% endif %}
        </div>

        <!-- Center/Right side: Phone, Email, Social -->
        <div class="header-craftsman__topbar-right">
          {% if section.settings.phone_number %}
            <a
              href="tel:{{ section.settings.phone_number | remove: ' ' | remove: '-' }}"
              class="header-craftsman__contact-link"
              aria-label="Call {{ section.settings.phone_number }}"
            >
              <svg class="header-craftsman__contact-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              {{ section.settings.phone_number }}
            </a>
          {% endif %}

          {% if section.settings.email %}
            <a
              href="mailto:{{ section.settings.email }}"
              class="header-craftsman__contact-link"
              aria-label="Email {{ section.settings.email }}"
            >
              <svg class="header-craftsman__contact-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </a>
          {% endif %}

          <!-- Social Links -->
          {% if section.blocks.size > 0 %}
            <div class="header-craftsman__social">
              {% for block in section.blocks %}
                {% if block.type == 'social_link' %}
                  <a
                    href="{{ block.settings.social_url }}"
                    class="header-craftsman__social-link"
                    aria-label="{{ block.settings.social_platform }} (opens in new window)"
                    target="_blank"
                    rel="noopener noreferrer"
                    {{ block.shopify_attributes }}
                  >
                    {% case block.settings.social_platform %}
                      {% when 'facebook' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                      {% when 'instagram' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0m6.066 5.934c.46 0 .833.373.833.833s-.373.833-.833.833-.833-.373-.833-.833.373-.833.833-.833m-3.066 5.066a2.667 2.667 0 10-5.334 0 2.667 2.667 0 005.334 0m4.934-7.5A4.566 4.566 0 0012 4.434a4.566 4.566 0 00-4.934 4.566v2.768a4.566 4.566 0 004.934 4.566A4.566 4.566 0 0016.934 11.768V9c0-1.381 1.119-2.5 2.5-2.5s2.5 1.119 2.5 2.5v5.768A8.334 8.334 0 0112 20.434 8.334 8.334 0 013.566 12 8.334 8.334 0 0112 3.566 8.334 8.334 0 0120.434 12v5.768"/>
                        </svg>
                      {% when 'twitter' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417a9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                        </svg>
                      {% when 'youtube' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                      {% when 'linkedin' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.945v5.442h-3.554s.05-8.733 0-9.65h3.554v1.368c.43-.66 1.191-1.603 2.926-1.603 2.136 0 3.747 1.394 3.747 4.393v5.492zM5.337 9.433c-1.144 0-1.915-.762-1.915-1.715 0-.955.77-1.715 1.916-1.715 1.144 0 1.915.76 1.915 1.715 0 .953-.771 1.715-1.915 1.715zm1.946 11.019H3.391V9.956h3.892v10.496zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
                        </svg>
                      {% when 'pinterest' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.223-.937 1.58-6.685 1.58-6.685s-.4-.8-.4-1.982c0-1.856 1.075-3.238 2.414-3.238 1.138 0 1.689.854 1.689 1.879 0 1.144-.728 2.85-1.104 4.432-.314 1.323.627 2.401 1.865 2.401 2.237 0 3.957-2.36 3.957-5.77 0-3.015-2.165-5.127-5.253-5.127-3.58 0-5.675 2.685-5.675 5.46 0 1.079.394 2.236.883 2.866.098.119.119.224.088.345l-.353 1.436c-.058.246-.19.3-.402.181-1.495-.742-2.432-3.08-2.432-4.95 0-4.006 2.91-7.674 8.39-7.674 4.412 0 7.839 3.143 7.839 7.347 0 4.383-2.767 7.91-6.514 7.91-1.271 0-2.468-.659-2.88-1.438l-.784 2.976c-.286 1.085-1.056 2.44-1.574 3.27.47.149.97.226 1.477.226 6.627 0 12-5.373 12-12 0-6.626-5.373-12-12-12z"/>
                        </svg>
                    {% endcase %}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}

  <!-- Main Header -->
  <div class="header-craftsman__main">
    <div class="header-craftsman__inner">
      <!-- Logo -->
      <div class="header-craftsman__logo">
        {% if section.settings.logo != blank %}
          <a href="{{ '/' | relative_url }}" class="header-craftsman__logo-link">
            {% assign logo_width_desktop = section.settings.logo_width_desktop | default: 200 %}
            {% assign logo_width_mobile = section.settings.logo_width_mobile | default: 100 %}
            <img
              src="{{ section.settings.logo | image_url: width: 300 }}"
              alt="{{ shop.name }}"
              class="header-craftsman__logo-image"
              style="--logo-width-desktop: {{ logo_width_desktop }}px; --logo-width-mobile: {{ logo_width_mobile }}px;"
              width="300"
              height="auto"
            />
          </a>
        {% else %}
          <a href="{{ '/' | relative_url }}" class="header-craftsman__logo-link header-craftsman__logo-text">
            {{ shop.name }}
          </a>
        {% endif %}
      </div>

      <!-- Navigation Menu -->
      <nav class="header-craftsman__nav" aria-label="Main navigation">
        {% if section.settings.menu != blank %}
          {% for link in linklists[section.settings.menu].links %}
            <a
              href="{{ link.url }}"
              class="header-craftsman__nav-link"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          {% endfor %}
        {% endif %}
      </nav>

      <!-- Right side: Actions (Icons + CTA) -->
      <div class="header-craftsman__actions">
        <!-- Header Icons Container -->
        <div class="header-craftsman__icons">
          <!-- Search: renders Dawn's native search snippet directly -->
          {%- if section.settings.show_search -%}
            {% render 'header-search', input_id: 'Search-In-Modal-Craftsman' %}
          {%- endif -%}

          <!-- Cart Icon (Custom Bag Style, NOT Dawn default) -->
          {%- if section.settings.show_cart -%}
            <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble" aria-label="{{ 'sections.header.cart_count' | t: count: cart.item_count }}">
              <svg class="icon icon-cart-craftsman" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <path d="M16 10a4 4 0 01-8 0"/>
              </svg>
              {%- if cart.item_count > 0 -%}
                <div class="cart-count-bubble">
                  <span aria-hidden="true">{{ cart.item_count }}</span>
                  <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
                </div>
              {%- endif -%}
            </a>
          {%- endif -%}

          <!-- Account Icon (always visible when enabled in Theme Editor) -->
          {%- if section.settings.show_account -%}
            <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset" aria-label="{{ 'customer.account_fallback' | t }}">
              <svg class="icon icon-account" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
                <circle cx="12" cy="8" r="5"/>
                <path d="M20 21a8 8 0 10-16 0"/>
              </svg>
            </a>
          {%- endif -%}
        </div>

        <!-- CTA Button -->
        {% if section.settings.cta_button_show %}
          <a
            href="{{ section.settings.cta_button_link }}"
            class="header-craftsman__cta-button header-craftsman__cta-button--{{ section.settings.cta_button_style }}"
          >
            {{ section.settings.cta_button_text }}
          </a>
        {% endif %}

        <!-- Mobile Menu Toggle -->
        <button
          class="header-craftsman__menu-toggle"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu-{{ section.id }}"
        >
          <span class="header-craftsman__menu-toggle-icon"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Drawer Menu -->
  <div
    id="mobile-menu-{{ section.id }}"
    class="header-craftsman__drawer"
    role="navigation"
    aria-label="Mobile navigation"
    hidden
  >
    <div class="header-craftsman__drawer-content">
      <!-- Mobile Icons Row -->
      <div class="header-craftsman__drawer-icons">
        {%- if section.settings.show_search -%}
          <a href="{{ routes.search_url }}" class="header__icon link focus-inset" aria-label="{{ 'general.search.search' | t }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.show_cart -%}
          <a href="{{ routes.cart_url }}" class="header__icon link focus-inset" aria-label="Cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            {%- if cart.item_count > 0 -%}
              <div class="cart-count-bubble">
                <span aria-hidden="true">{{ cart.item_count }}</span>
              </div>
            {%- endif -%}
          </a>
        {%- endif -%}

        {%- if section.settings.show_account -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon link focus-inset" aria-label="{{ 'customer.account_fallback' | t }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
              <circle cx="12" cy="8" r="5"/>
              <path d="M20 21a8 8 0 10-16 0"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <nav class="header-craftsman__drawer-nav">
        {% if section.settings.menu != blank %}
          {% for link in linklists[section.settings.menu].links %}
            <a
              href="{{ link.url }}"
              class="header-craftsman__drawer-nav-link"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          {% endfor %}
        {% endif %}
      </nav>

      {% if section.settings.cta_button_show %}
        <a
          href="{{ section.settings.cta_button_link }}"
          class="header-craftsman__drawer-cta-button header-craftsman__cta-button--{{ section.settings.cta_button_style }}"
        >
          {{ section.settings.cta_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</header>
</header-craftsman>

<style>
  #shopify-section-{{ section.id }} {
    --header-bg: rgb(var(--color-background));
    --header-text: rgb(var(--color-foreground));
    --header-link: rgb(var(--color-button));
    --topbar-height: 36px;
    --main-header-height: 70px;
    --total-header-height: 106px;
  }

  /* Sticky Header Modes */
  {% if section.settings.sticky_mode == 'always' %}
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 100;
  }
  #shopify-section-{{ section.id }}.header-sticky--active .header-craftsman {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  {% elsif section.settings.sticky_mode == 'on-scroll' %}
  #shopify-section-{{ section.id }} {
    z-index: 100;
  }
  #shopify-section-{{ section.id }}.header-sticky--active {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
  }
  #shopify-section-{{ section.id }}.header-sticky--active .header-craftsman {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  {% endif %}

  /* Top Bar */
  .header-craftsman__topbar {
    background-color: var(--topbar-bg);
    border-bottom: 1px solid rgb(var(--color-border));
    font-size: 16px;
    height: var(--topbar-height);
    display: flex;
    align-items: center;
    padding: 0 20px;
  }

  .header-craftsman__topbar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .header-craftsman__topbar-left {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .header-craftsman__topbar-right {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .header-craftsman__emergency-badge {
    background-color: rgb(var(--color-button));
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 16px;
  }

  .header-craftsman__hours {
    font-weight: 500;
    color: rgb(var(--color-foreground));
  }

  .header-craftsman__contact-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--header-link);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .header-craftsman__contact-link:hover {
    opacity: 0.7;
  }

  .header-craftsman__contact-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .header-craftsman__social {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .header-craftsman__social-link {
    display: inline-flex;
    width: 20px;
    height: 20px;
    color: var(--header-link);
    transition: transform 0.2s;
  }

  .header-craftsman__social-link:hover {
    transform: scale(1.15);
  }

  .header-craftsman__social-link svg {
    width: 100%;
    height: 100%;
  }

  /* Main Header */
  .header-craftsman__main {
    background-color: var(--header-bg);
    border-bottom: 1px solid rgb(var(--color-border));
    height: var(--main-header-height);
    display: flex;
    align-items: center;
    transition: background-color 0.3s;
  }

  .header-craftsman__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .header-craftsman__logo {
    flex-shrink: 0;
  }

  .header-craftsman__logo-link {
    display: flex;
    align-items: center;
    color: var(--header-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 20px;
  }

  .header-craftsman__logo-image {
    max-width: var(--logo-width-desktop);
    height: auto;
    display: block;
  }

  .header-craftsman__nav {
    display: flex;
    gap: 30px;
    flex: 1;
    align-items: center;
  }

  .header-craftsman__nav-link {
    color: var(--header-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 16px;
    position: relative;
    transition: color 0.2s;
  }

  .header-craftsman__nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--header-link);
    transition: width 0.3s;
  }

  .header-craftsman__nav-link:hover::after,
  .header-craftsman__nav-link[aria-current]::after {
    width: 100%;
  }

  /* Header Icons - use Dawn's native .header__icon classes */
  .header-craftsman__icons {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-craftsman__icons .header__icon {
    color: var(--header-text);
  }

  /* Custom cart icon styling (bag icon instead of Dawn's default) */
  .icon-cart-craftsman {
    width: 2.4rem;
    height: 2.4rem;
  }

  /* Actions Container */
  .header-craftsman__actions {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .header-craftsman__cta-button {
    padding: 10px 20px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }

  .header-craftsman__cta-button--filled {
    background-color: rgb(var(--color-button));
    color: white;
  }

  .header-craftsman__cta-button--filled:hover {
    background-color: rgba(var(--color-foreground), 0.85);
  }

  .header-craftsman__cta-button--outline {
    border: 2px solid rgb(var(--color-button));
    color: rgb(var(--color-button));
  }

  .header-craftsman__cta-button--outline:hover {
    background-color: rgb(var(--color-button));
    color: white;
  }

  /* Menu Toggle */
  .header-craftsman__menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
  }

  .header-craftsman__menu-toggle-icon {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--header-text);
    position: relative;
    transition: all 0.3s;
  }

  .header-craftsman__menu-toggle-icon::before,
  .header-craftsman__menu-toggle-icon::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background-color: var(--header-text);
    transition: all 0.3s;
  }

  .header-craftsman__menu-toggle-icon::before {
    top: -8px;
  }

  .header-craftsman__menu-toggle-icon::after {
    bottom: -8px;
  }

  .header-craftsman__menu-toggle[aria-expanded="true"] .header-craftsman__menu-toggle-icon {
    background: transparent;
  }

  .header-craftsman__menu-toggle[aria-expanded="true"] .header-craftsman__menu-toggle-icon::before {
    transform: rotate(45deg);
    top: 0;
  }

  .header-craftsman__menu-toggle[aria-expanded="true"] .header-craftsman__menu-toggle-icon::after {
    transform: rotate(-45deg);
    bottom: 0;
  }

  /* Mobile Drawer */
  .header-craftsman__drawer {
    display: none;
    position: fixed;
    top: var(--total-header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--header-bg);
    border-top: 1px solid rgb(var(--color-border));
    z-index: 99;
    overflow-y: auto;
    animation: slideDown 0.3s ease-out;
  }

  .header-craftsman__drawer[hidden] {
    display: none !important;
  }

  @keyframes slideDown {
    from {
      transform: translateY(-10px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .header-craftsman__drawer-content {
    padding: 20px;
  }

  .header-craftsman__drawer-icons {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgb(var(--color-border));
  }

  .header-craftsman__drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 20px;
  }

  .header-craftsman__drawer-nav-link {
    display: block;
    padding: 14px 0;
    color: var(--header-text);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid rgb(var(--color-border));
  }

  .header-craftsman__drawer-nav-link:last-child {
    border-bottom: none;
  }

  .header-craftsman__drawer-cta-button {
    width: 100%;
    text-align: center;
  }

  /* Search uses Dawn's native search-modal styles - no custom overrides needed */

  /* Mobile Responsive */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      --topbar-height: 0px;
      --main-header-height: 60px;
      --total-header-height: 60px;
    }

    .header-craftsman__topbar {
      display: none;
    }

    .header-craftsman__nav {
      display: none;
    }

    .header-craftsman__menu-toggle {
      display: flex;
    }

    .header-craftsman__cta-button {
      display: none;
    }

    .header-craftsman__logo-image {
      max-width: var(--logo-width-mobile);
    }

    .header-craftsman__drawer:not([hidden]) {
      display: flex;
      flex-direction: column;
    }

    .header-craftsman__drawer-content {
      flex: 1;
    }

    .header__search-modal {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      min-width: 90%;
      max-width: 500px;
      border-radius: 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header-craftsman__nav-link::after,
    .header-craftsman__contact-link,
    .header-craftsman__social-link,
    .header-craftsman__icon,
    .header-craftsman__menu-toggle-icon,
    .header-craftsman__cta-button {
      transition: none;
    }
  }
</style>

<script>
  class HeaderCraftsman extends HTMLElement {
    connectedCallback() {
      this.header = this.querySelector('[role="banner"]');
      this.sectionId = this.header?.dataset.sectionId || '';
      this.menuToggle = this.querySelector('[aria-controls]');
      this.drawer = document.getElementById(`mobile-menu-${this.sectionId}`);
      this.linksInDrawer = this.drawer?.querySelectorAll('.header-craftsman__drawer-nav-link') || [];
      this.stickyMode = this.header?.dataset.sticky || 'none';
      this.stickyThreshold = 100;
      this.lastScrollY = 0;
      this.isScrollingUp = false;

      if (this.menuToggle) {
        this.menuToggle.addEventListener('click', () => this.toggleDrawer());
      }

      // Close drawer when a link is clicked
      this.linksInDrawer.forEach(link => {
        link.addEventListener('click', () => this.closeDrawer());
      });

      // Close drawer on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isDrawerOpen()) {
          this.closeDrawer();
        }
      });

      // Setup sticky on scroll logic
      if (this.stickyMode === 'on-scroll') {
        this.setupScrollListener();
      }

      // Handle shopify:section:unload
      this.addEventListener('shopify:section:unload', () => {
        this.cleanup();
      });
    }

    setupScrollListener() {
      const sectionWrapper = document.getElementById(`shopify-section-${this.sectionId}`);
      let scrollTimeout;

      window.addEventListener('scroll', () => {
        clearTimeout(scrollTimeout);
        const currentScrollY = window.scrollY;
        this.isScrollingUp = currentScrollY < this.lastScrollY;
        this.lastScrollY = currentScrollY;

        if (currentScrollY > this.stickyThreshold && this.isScrollingUp) {
          if (sectionWrapper) {
            sectionWrapper.classList.add('header-sticky--active');
          }
        } else {
          if (sectionWrapper) {
            sectionWrapper.classList.remove('header-sticky--active');
          }
        }

        scrollTimeout = setTimeout(() => {
          if (currentScrollY < this.stickyThreshold) {
            if (sectionWrapper) {
              sectionWrapper.classList.remove('header-sticky--active');
            }
          }
        }, 150);
      });
    }

    toggleDrawer() {
      if (this.isDrawerOpen()) {
        this.closeDrawer();
      } else {
        this.openDrawer();
      }
    }

    openDrawer() {
      if (this.drawer) {
        this.drawer.removeAttribute('hidden');
        this.menuToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        const firstLink = this.linksInDrawer[0];
        if (firstLink) setTimeout(() => firstLink.focus(), 100);
      }
    }

    closeDrawer() {
      if (this.drawer) {
        this.drawer.setAttribute('hidden', '');
        this.menuToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        this.menuToggle.focus();
      }
    }

    isDrawerOpen() {
      return this.drawer && !this.drawer.hasAttribute('hidden');
    }

    cleanup() {
      if (this.menuToggle) {
        this.menuToggle.removeEventListener('click', () => this.toggleDrawer());
      }
      this.linksInDrawer.forEach(link => {
        link.removeEventListener('click', () => this.closeDrawer());
      });
      window.removeEventListener('scroll', () => {});
    }
  }

  if (!customElements.get('header-craftsman')) {
    customElements.define('header-craftsman', HeaderCraftsman);
  }
</script>

