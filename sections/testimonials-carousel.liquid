{%- liquid
  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag
  assign heading_alignment = section.settings.heading_alignment
  assign subheading = section.settings.subheading
  assign layout = section.settings.layout
  assign card_style = section.settings.card_style
  assign show_rating = section.settings.show_rating
  assign show_author_photo = section.settings.show_author_photo
  assign show_quote_icon = section.settings.show_quote_icon
  assign auto_play = section.settings.auto_play
  assign auto_play_speed = section.settings.auto_play_speed
  assign show_aggregate_rating = section.settings.show_aggregate_rating
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  assign total_testimonials = section.blocks | size
  assign aggregate_rating = 0

  for block in section.blocks
    assign aggregate_rating = aggregate_rating | plus: block.settings.rating | divided_by: total_testimonials
  endfor
-%}

<div
  id="shopify-section-{{ section.id }}"
  class="testimonials-carousel color-scheme--{{ color_scheme }}"
  style="
    --padding-top: {{ padding_top }}px;
    --padding-bottom: {{ padding_bottom }}px;
  "
  data-layout="{{ layout }}"
>
  <div class="testimonials-carousel__wrapper">
    <div class="testimonials-carousel__header" style="text-align: {{ heading_alignment }};">
      <{{ heading_tag }} class="testimonials-carousel__heading">
        {{ heading }}
      </{{ heading_tag }}>
      {% if subheading %}
        <p class="testimonials-carousel__subheading">{{ subheading }}</p>
      {% endif %}

      {% if show_aggregate_rating and total_testimonials > 0 %}
        <div class="testimonials-carousel__aggregate" aria-label="Average customer rating">
          <div class="testimonials-carousel__stars">
            {%- for i in (1..5) -%}
              {%- if i <= aggregate_rating -%}
                <span class="testimonials-carousel__star testimonials-carousel__star--filled" aria-hidden="true">★</span>
              {%- else -%}
                <span class="testimonials-carousel__star" aria-hidden="true">☆</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="testimonials-carousel__aggregate-text">
            {{ aggregate_rating | round: 1 }} out of 5
          </span>
        </div>
      {% endif %}
    </div>

    <div
      class="testimonials-carousel__carousel"
      role="region"
      aria-roledescription="carousel"
      aria-label="Customer testimonials"
      data-auto-play="{{ auto_play | default: false }}"
      data-auto-play-speed="{{ auto_play_speed | default: 5 }}"
    >
      <div class="testimonials-carousel__track">
        {%- for block in section.blocks -%}
          {%- liquid
            assign quote = block.settings.quote
            assign author_name = block.settings.author_name
            assign author_role = block.settings.author_role
            assign author_image = block.settings.author_image
            assign rating = block.settings.rating
          -%}

          <div
            class="testimonials-carousel__slide testimonials-carousel__card--{{ card_style }}"
            role="group"
            aria-roledescription="slide"
            aria-label="Testimonial {{ forloop.index }} of {{ total_testimonials }}"
            tabindex="0"
          >
            <div class="testimonials-carousel__card">
              {% if show_quote_icon %}
                <div class="testimonials-carousel__quote-icon" aria-hidden="true">
                  <span>"</span>
                </div>
              {% endif %}

              {% if quote %}
                <blockquote class="testimonials-carousel__quote">
                  {{ quote }}
                </blockquote>
              {% endif %}

              <div class="testimonials-carousel__footer">
                {% if show_author_photo and author_image %}
                  <div class="testimonials-carousel__author-photo">
                    <img
                      src="{{ author_image | image_url: width: 120 }}"
                      alt="{{ author_name | escape }}"
                      loading="lazy"
                      width="60"
                      height="60"
                    />
                  </div>
                {% endif %}

                <div class="testimonials-carousel__author-info">
                  {% if author_name %}
                    <p class="testimonials-carousel__author-name">
                      {{ author_name }}
                    </p>
                  {% endif %}
                  {% if author_role %}
                    <p class="testimonials-carousel__author-role">
                      {{ author_role }}
                    </p>
                  {% endif %}
                </div>

                {% if show_rating %}
                  <div
                    class="testimonials-carousel__rating"
                    aria-label="Rated {{ rating }} out of 5 stars"
                  >
                    {%- for i in (1..5) -%}
                      {%- if i <= rating -%}
                        <span class="testimonials-carousel__star testimonials-carousel__star--filled" aria-hidden="true">★</span>
                      {%- else -%}
                        <span class="testimonials-carousel__star" aria-hidden="true">☆</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {% if layout contains 'carousel' %}
        <div class="testimonials-carousel__controls">
          <button
            class="testimonials-carousel__button testimonials-carousel__button--prev"
            aria-label="Previous testimonial"
            aria-controls="carousel-track"
          >
            <span aria-hidden="true">‹</span>
          </button>

          <div
            class="testimonials-carousel__dots"
            role="tablist"
            aria-label="Slide selection"
          >
            {%- for i in (1..total_testimonials) -%}
              <button
                class="testimonials-carousel__dot {% if i == 1 %}testimonials-carousel__dot--active{% endif %}"
                role="tab"
                aria-selected="{% if i == 1 %}true{% else %}false{% endif %}"
                aria-label="Go to slide {{ i }}"
                data-slide="{{ i | minus: 1 }}"
              ></button>
            {%- endfor -%}
          </div>

          <button
            class="testimonials-carousel__button testimonials-carousel__button--next"
            aria-label="Next testimonial"
            aria-controls="carousel-track"
          >
            <span aria-hidden="true">›</span>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --color-foreground: rgb(var(--color-foreground));
    --color-background: rgb(var(--color-background));
    --color-accent: rgb(var(--color-accent));

    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .testimonials-carousel__wrapper {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .testimonials-carousel__header {
    margin-bottom: 2rem;
  }

  .testimonials-carousel__heading {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 600;
    margin: 0;
    color: var(--color-foreground);
  }

  .testimonials-carousel__subheading {
    font-size: 1rem;
    margin: 0.5rem 0 0 0;
    color: var(--color-foreground);
    opacity: 0.85;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .testimonials-carousel__aggregate {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .testimonials-carousel__stars {
    display: flex;
    gap: 0.25rem;
  }

  .testimonials-carousel__star {
    font-size: 1.25rem;
    color: var(--color-foreground);
    opacity: 0.4;
  }

  .testimonials-carousel__star--filled {
    color: var(--color-accent);
    opacity: 1;
  }

  .testimonials-carousel__aggregate-text {
    font-size: 0.875rem;
    color: var(--color-foreground);
    opacity: 0.8;
  }

  /* Carousel container */
  .testimonials-carousel__carousel {
    position: relative;
  }

  .testimonials-carousel__track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .testimonials-carousel__track::-webkit-scrollbar {
    display: none;
  }

  /* Layout variants */
  [data-layout="carousel-single"] .testimonials-carousel__track {
    overflow-x: auto;
  }

  [data-layout="carousel-single"] .testimonials-carousel__slide {
    flex: 0 0 100%;
  }

  [data-layout="carousel-multi"] .testimonials-carousel__track {
    overflow-x: auto;
  }

  [data-layout="carousel-multi"] .testimonials-carousel__slide {
    flex: 0 0 calc(50% - 0.75rem);
  }

  [data-layout="grid-2"] .testimonials-carousel__track {
    flex-wrap: wrap;
    justify-content: center;
    overflow-x: visible;
  }

  [data-layout="grid-2"] .testimonials-carousel__slide {
    flex: 1 1 calc(50% - 0.75rem);
    max-width: 500px;
  }

  [data-layout="grid-3"] .testimonials-carousel__track {
    flex-wrap: wrap;
    justify-content: center;
    overflow-x: visible;
  }

  [data-layout="grid-3"] .testimonials-carousel__slide {
    flex: 1 1 calc(33.333% - 1rem);
    max-width: 380px;
  }

  /* Slides */
  .testimonials-carousel__slide {
    flex-shrink: 0;
    scroll-snap-align: start;
    outline: none;
  }

  .testimonials-carousel__slide:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* Card styling */
  .testimonials-carousel__card {
    height: 100%;
    padding: 1.5rem;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background-color: var(--color-background);
    position: relative;
  }

  .testimonials-carousel__card--elevated {
    background-color: var(--color-background);
    box-shadow: 0 2px 8px rgba(var(--color-foreground), 0.08);
  }

  .testimonials-carousel__card--bordered {
    border: 1px solid var(--color-foreground);
    border-opacity: 0.15;
  }

  .testimonials-carousel__card--minimal {
    background-color: transparent;
    border-left: 3px solid var(--color-accent);
    padding-left: 1.5rem;
  }

  .testimonials-carousel__quote-icon {
    font-size: 2.5rem;
    color: var(--color-accent);
    opacity: 0.3;
    font-family: Georgia, serif;
    margin-bottom: 0.5rem;
    height: 2rem;
  }

  .testimonials-carousel__quote {
    margin: 0 0 1.5rem 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-foreground);
    font-style: italic;
    flex-grow: 1;
  }

  .testimonials-carousel__footer {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding-top: 1rem;
    border-top: 1px solid var(--color-foreground);
    border-top-opacity: 0.1;
  }

  .testimonials-carousel__card--minimal .testimonials-carousel__footer {
    border-top: none;
    padding-top: 0;
  }

  .testimonials-carousel__author-photo {
    flex-shrink: 0;
  }

  .testimonials-carousel__author-photo img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonials-carousel__author-info {
    flex-grow: 1;
    min-width: 0;
  }

  .testimonials-carousel__author-name {
    margin: 0 0 0.25rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .testimonials-carousel__author-role {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  .testimonials-carousel__rating {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  /* Controls */
  .testimonials-carousel__controls {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    margin-top: 2rem;
  }

  .testimonials-carousel__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: var(--color-background);
    border: 1px solid var(--color-foreground);
    border-opacity: 0.15;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.5rem;
    color: var(--color-foreground);
    transition: all 0.2s ease;
    padding: 0;
  }

  .testimonials-carousel__button:hover {
    background-color: var(--color-accent);
    color: var(--color-background);
    border-color: var(--color-accent);
  }

  .testimonials-carousel__button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .testimonials-carousel__dots {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .testimonials-carousel__dot {
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-foreground);
    border-opacity: 0.3;
    border-radius: 50%;
    background-color: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .testimonials-carousel__dot:hover {
    border-color: var(--color-accent);
    border-opacity: 1;
  }

  .testimonials-carousel__dot--active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .testimonials-carousel__dot:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .testimonials-carousel__wrapper {
      padding: 0 1rem;
    }

    .testimonials-carousel__header {
      margin-bottom: 1.5rem;
    }

    [data-layout="carousel-multi"] .testimonials-carousel__slide {
      flex: 0 0 calc(100% - 0);
    }

    [data-layout="grid-2"] .testimonials-carousel__slide {
      flex: 1 1 100%;
    }

    [data-layout="grid-3"] .testimonials-carousel__slide {
      flex: 1 1 100%;
    }

    .testimonials-carousel__card {
      padding: 1.25rem;
    }

    .testimonials-carousel__controls {
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .testimonials-carousel__button {
      width: 40px;
      height: 40px;
      font-size: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    [data-layout="carousel-single"] .testimonials-carousel__slide,
    [data-layout="carousel-multi"] .testimonials-carousel__slide {
      flex: 0 0 100%;
    }

    .testimonials-carousel__track {
      gap: 1rem;
    }

    .testimonials-carousel__card {
      padding: 1rem;
    }

    .testimonials-carousel__quote {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .testimonials-carousel__footer {
      gap: 0.75rem;
    }

    .testimonials-carousel__author-photo img {
      width: 50px;
      height: 50px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
      transition: none !important;
    }

    .testimonials-carousel__track {
      scroll-behavior: auto;
    }
  }
</style>

<script type="module">
  class TestimonialsCarouselSection extends HTMLElement {
    connectedCallback() {
      this.carousel = this.querySelector('[role="region"]');
      this.track = this.querySelector('.testimonials-carousel__track');
      this.layout = this.dataset.layout;
      this.autoPlay = this.carousel.dataset.autoPlay === 'true';
      this.autoPlaySpeed = parseInt(this.carousel.dataset.autoPlaySpeed) * 1000;
      this.prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      this.currentSlide = 0;
      this.autoPlayTimeout = null;

      if (this.layout.includes('carousel')) {
        this.initCarousel();
      }

      if (window.Shopify?.designMode) {
        this.setupThemeEditorListeners();
      }
    }

    initCarousel() {
      this.slides = this.querySelectorAll('.testimonials-carousel__slide');
      this.prevButton = this.querySelector('.testimonials-carousel__button--prev');
      this.nextButton = this.querySelector('.testimonials-carousel__button--next');
      this.dots = this.querySelectorAll('.testimonials-carousel__dot');

      this.prevButton?.addEventListener('click', () => this.previousSlide());
      this.nextButton?.addEventListener('click', () => this.nextSlide());

      this.dots.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          this.goToSlide(parseInt(e.target.dataset.slide));
        });
      });

      this.track.addEventListener('keydown', (e) => this.handleKeyboard(e));
      this.slides.forEach((slide) => {
        slide.addEventListener('focus', () => this.pauseAutoPlay());
        slide.addEventListener('blur', () => this.resumeAutoPlay());
      });

      this.carousel.addEventListener('mouseenter', () => this.pauseAutoPlay());
      this.carousel.addEventListener('mouseleave', () => this.resumeAutoPlay());

      if (this.autoPlay && !this.prefersReducedMotion) {
        this.startAutoPlay();
      }

      this.updateCarousel();
    }

    previousSlide() {
      this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
      this.updateCarousel();
      this.pauseAutoPlay();
    }

    nextSlide() {
      this.currentSlide = (this.currentSlide + 1) % this.slides.length;
      this.updateCarousel();
      this.pauseAutoPlay();
    }

    goToSlide(index) {
      this.currentSlide = index;
      this.updateCarousel();
      this.pauseAutoPlay();
    }

    updateCarousel() {
      const slideWidth = this.slides[0].offsetWidth + 24; // 24px is gap
      this.track.scrollLeft = this.currentSlide * slideWidth;

      this.dots.forEach((dot, index) => {
        if (index === this.currentSlide) {
          dot.classList.add('testimonials-carousel__dot--active');
          dot.setAttribute('aria-selected', 'true');
        } else {
          dot.classList.remove('testimonials-carousel__dot--active');
          dot.setAttribute('aria-selected', 'false');
        }
      });

      this.slides.forEach((slide, index) => {
        if (index === this.currentSlide) {
          slide.focus();
        }
      });
    }

    handleKeyboard(e) {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        this.previousSlide();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        this.nextSlide();
      }
    }

    startAutoPlay() {
      this.autoPlayTimeout = setInterval(() => {
        this.nextSlide();
      }, this.autoPlaySpeed);
    }

    pauseAutoPlay() {
      if (this.autoPlayTimeout) {
        clearInterval(this.autoPlayTimeout);
        this.autoPlayTimeout = null;
      }
    }

    resumeAutoPlay() {
      if (this.autoPlay && !this.prefersReducedMotion) {
        this.startAutoPlay();
      }
    }

    setupThemeEditorListeners() {
      document.addEventListener('shopify:section:load', (e) => {
        if (e.detail.sectionId === this.id.replace('shopify-section-', '')) {
          this.connectedCallback();
        }
      });
    }

    disconnectedCallback() {
      this.pauseAutoPlay();
    }
  }

  if (!customElements.get('testimonials-carousel-section')) {
    customElements.define('testimonials-carousel-section', TestimonialsCarouselSection);
  }
</script>

{% schema %}
{
  "name": "Testimonials Carousel",
  "description": "Display customer testimonials and reviews in a carousel or grid layout",
  "class": "testimonials-carousel-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Trusted by craftspeople and homeowners everywhere"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "carousel-single", "label": "Carousel (single)" },
        { "value": "carousel-multi", "label": "Carousel (multi-visible)" },
        { "value": "grid-2", "label": "Grid (2 columns)" },
        { "value": "grid-3", "label": "Grid (3 columns)" }
      ],
      "default": "carousel-single"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "options": [
        { "value": "elevated", "label": "Elevated" },
        { "value": "bordered", "label": "Bordered" },
        { "value": "minimal", "label": "Minimal" }
      ],
      "default": "elevated"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author_photo",
      "label": "Show author photo",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quote_icon",
      "label": "Show quote icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_aggregate_rating",
      "label": "Show aggregate rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "auto_play",
      "label": "Enable auto-play",
      "default": false
    },
    {
      "type": "range",
      "id": "auto_play_speed",
      "label": "Auto-play speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This is an amazing product. The quality is outstanding and the service was exceptional."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "John Smith"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "Author role / company",
          "default": "Homeowner"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
