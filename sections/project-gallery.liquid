{%- style -%}
  #shopify-section-{{ section.id }} {
    --color-background: var(--color-background-1);
    --color-text: var(--color-text);
    --color-text-secondary: var(--color-text-secondary);
    --color-border: var(--color-border);
  }

  #shopify-section-{{ section.id }} .section-container {
    max-width: 100%;
    padding: {{ section.settings.padding_top }}px {% if section.settings.padding_top == section.settings.padding_bottom %} {{ section.settings.padding_bottom }}px {% else %} {{ section.settings.padding_bottom }}px {% endif %};
  }

  #shopify-section-{{ section.id }} .heading-wrapper {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .section-heading {
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .section-subheading {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: clamp(0.875rem, 2vw, 1.125rem);
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
    justify-content: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .filter-button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: var(--color-text);
    font-size: 0.875rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .filter-button:hover {
    border-color: var(--color-text);
  }

  #shopify-section-{{ section.id }} .filter-button[aria-pressed="true"] {
    background: var(--color-text);
    color: var(--color-background);
  }

  #shopify-section-{{ section.id }} .projects-grid {
    display: grid;
    gap: {{ section.settings.gap }}px;
    margin-bottom: 2rem;
  }

  {% if section.settings.layout == 'masonry' %}
    #shopify-section-{{ section.id }} .projects-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      grid-auto-rows: auto;
    }

    #shopify-section-{{ section.id }} .project-item:nth-child(2n) {
      grid-row: span 1.2;
    }
  {% elsif section.settings.layout == 'grid-2' %}
    #shopify-section-{{ section.id }} .projects-grid {
      grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} .projects-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  {% elsif section.settings.layout == 'grid-3' %}
    #shopify-section-{{ section.id }} .projects-grid {
      grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} .projects-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      #shopify-section-{{ section.id }} .projects-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  {% elsif section.settings.layout == 'grid-4' %}
    #shopify-section-{{ section.id }} .projects-grid {
      grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} .projects-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      #shopify-section-{{ section.id }} .projects-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }
  {% endif %}

  #shopify-section-{{ section.id }} .project-item {
    opacity: 1;
    transition: {% if section.settings.filter_animation == 'fade' %}opacity 0.3s ease{% else %}all 0.3s ease{% endif %};
  }

  #shopify-section-{{ section.id }} .project-item.hidden {
    display: none;
  }

  #shopify-section-{{ section.id }} .project-image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.corner_radius }}px;
    cursor: pointer;
    background: var(--color-background);
  }

  {% if section.settings.image_aspect_ratio == '1:1' %}
    #shopify-section-{{ section.id }} .project-image-wrapper {
      aspect-ratio: 1;
    }
  {% elsif section.settings.image_aspect_ratio == '4:3' %}
    #shopify-section-{{ section.id }} .project-image-wrapper {
      aspect-ratio: 4 / 3;
    }
  {% elsif section.settings.image_aspect_ratio == '3:2' %}
    #shopify-section-{{ section.id }} .project-image-wrapper {
      aspect-ratio: 3 / 2;
    }
  {% elsif section.settings.image_aspect_ratio == '16:9' %}
    #shopify-section-{{ section.id }} .project-image-wrapper {
      aspect-ratio: 16 / 9;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background: {% if section.settings.hover_overlay == 'gradient' %}linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent){% else %}rgba(0, 0, 0, 0){% endif %};
    transition: {% if section.settings.hover_overlay == 'slide-up' %}transform 0.3s ease, opacity 0.3s ease{% else %}opacity 0.3s ease{% endif %};
    {% if section.settings.hover_overlay == 'slide-up' %}
      transform: translateY(100%);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .project-image-wrapper:hover .project-overlay,
  #shopify-section-{{ section.id }} .project-image-wrapper:focus-within .project-overlay {
    {% if section.settings.hover_overlay == 'slide-up' %}
      transform: translateY(0);
    {% else %}
      opacity: 1;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .overlay-content {
    color: white;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .overlay-title {
    margin: 0 0 0.25rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .overlay-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.9;
  }

  #shopify-section-{{ section.id }} .project-info {
    padding: 1rem 0;
  }

  #shopify-section-{{ section.id }} .project-title {
    margin: 0.5rem 0 0 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .project-category {
    display: inline-block;
    margin: 0.5rem 0;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-background);
    color: var(--color-text-secondary);
    border-radius: 2px;
  }

  #shopify-section-{{ section.id }} .project-description {
    margin: 0.5rem 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .project-link {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.875rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-text);
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .project-link:hover {
    opacity: 0.7;
  }

  #shopify-section-{{ section.id }} .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    backdrop-filter: blur(4px);
  }

  #shopify-section-{{ section.id }} .lightbox[open] {
    display: flex;
  }

  #shopify-section-{{ section.id }} .lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    background: white;
    border-radius: {{ section.settings.corner_radius }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .lightbox-image {
    max-width: 100%;
    max-height: 80vh;
    display: block;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    transition: all 0.2s ease;
    z-index: 10;
  }

  #shopify-section-{{ section.id }} .lightbox-close:hover {
    background: white;
  }

  #shopify-section-{{ section.id }} .lightbox-close:focus-visible {
    outline: 2px solid #4A90E2;
    outline-offset: 2px;
  }

  #shopify-section-{{ section.id }} .load-more-wrapper {
    text-align: center;
    margin-top: 2rem;
  }

  #shopify-section-{{ section.id }} .load-more-button {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--color-text);
    color: var(--color-background);
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .load-more-button:hover {
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .load-more-button:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  #shopify-section-{{ section.id }} .view-all-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-text);
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .view-all-link:hover {
    opacity: 0.7;
  }

  #shopify-section-{{ section.id }} .placeholder-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-border);
    color: var(--color-text-secondary);
    font-size: 3rem;
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} * {
      animation: none !important;
      transition: none !important;
    }
  }
{%- endstyle -%}

<div class="section-container color-scheme--{{ section.settings.color_scheme }}">
  <div class="heading-wrapper">
    <{{ section.settings.heading_level }} class="section-heading">{{ section.settings.heading }}</{{ section.settings.heading_level }}>
    {% if section.settings.subheading != blank %}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  {% if section.settings.show_filter_bar and section.blocks.size > 0 %}
    <div class="filter-bar" role="tablist" aria-label="Project categories">
      <button class="filter-button" data-filter="all" aria-pressed="true" role="tab" aria-selected="true">
        All
      </button>
      {%- assign categories = '' | split: ',' -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.category != blank -%}
          {%- assign cat = block.settings.category | strip -%}
          {%- unless categories contains cat -%}
            {%- assign categories = categories | push: cat -%}
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
      {%- for category in categories -%}
        <button class="filter-button" data-filter="{{ category | downcase | replace: ' ', '-' }}" role="tab" aria-selected="false" aria-label="Filter projects by {{ category }}">
          {{ category }}
        </button>
      {%- endfor -%}
    </div>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="projects-grid" data-show-count="{{ section.settings.initial_show_count }}">
      {%- for block in section.blocks -%}
        {%- capture category_filter -%}{{ block.settings.category | downcase | replace: ' ', '-' }}{%- endcapture -%}
        <div class="project-item" data-category="{{ category_filter }}" data-index="{{ forloop.index0 }}" {% if forloop.index0 >= section.settings.initial_show_count %}style="display: none;"{% endif %}>
          <div class="project-image-wrapper" tabindex="0" role="button" aria-label="View project: {{ block.settings.title }}" data-image-index="{{ forloop.index0 }}">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title }}"
                class="project-image"
                loading="lazy"
                width="800"
                height="600"
              >
            {% else %}
              <div class="placeholder-image">📷</div>
            {% endif %}
            <div class="project-overlay">
              <div class="overlay-content">
                {% if block.settings.category != blank %}
                  <span class="overlay-category">{{ block.settings.category }}</span>
                {% endif %}
                <h3 class="overlay-title">{{ block.settings.title }}</h3>
              </div>
            </div>
          </div>
          <div class="project-info">
            <h3 class="project-title">{{ block.settings.title }}</h3>
            {% if block.settings.category != blank %}
              <span class="project-category">{{ block.settings.category }}</span>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="project-description">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.link_url != blank %}
              <a href="{{ block.settings.link_url }}" class="project-link">{{ block.settings.link_text | default: 'View Project' }}</a>
            {% endif %}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {% if section.blocks.size > section.settings.initial_show_count %}
      <div class="load-more-wrapper">
        <button class="load-more-button" data-load-more aria-label="Load more projects">
          Load More
        </button>
      </div>
    {% endif %}

    {% if section.settings.show_view_all and section.settings.view_all_url != blank %}
      <div style="text-align: center;">
        <a href="{{ section.settings.view_all_url }}" class="view-all-link">View All Projects</a>
      </div>
    {% endif %}

    {% if section.settings.show_lightbox %}
      <dialog class="lightbox" aria-label="Project image lightbox" aria-modal="true">
        <div class="lightbox-content">
          <button class="lightbox-close" aria-label="Close lightbox">×</button>
          <img class="lightbox-image" src="" alt="">
        </div>
      </dialog>
    {% endif %}
  {% else %}
    <p style="text-align: center; color: var(--color-text-secondary); padding: 2rem;">
      Add project blocks to display your work.
    </p>
  {% endif %}
</div>

<script type="module">
  class ProjectGallery extends HTMLElement {
    connectedCallback() {
      this.grid = this.querySelector('[data-show-count]');
      this.showCount = parseInt(this.grid?.dataset.showCount || 4);
      this.filterButtons = this.querySelectorAll('.filter-button');
      this.projectItems = this.querySelectorAll('.project-item');
      this.loadMoreBtn = this.querySelector('[data-load-more]');
      this.lightbox = this.querySelector('.lightbox');
      this.imageWrappers = this.querySelectorAll('.project-image-wrapper');

      this.initFilters();
      this.initLightbox();
      this.initLoadMore();
      this.initKeyboard();
    }

    initFilters() {
      this.filterButtons.forEach((btn) => {
        btn.addEventListener('click', () => this.handleFilter(btn));
        btn.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            this.handleFilter(btn);
          }
        });
      });
    }

    handleFilter(btn) {
      this.filterButtons.forEach((b) => {
        b.setAttribute('aria-pressed', 'false');
        b.setAttribute('aria-selected', 'false');
      });
      btn.setAttribute('aria-pressed', 'true');
      btn.setAttribute('aria-selected', 'true');

      const filter = btn.dataset.filter;
      let visibleCount = 0;

      this.projectItems.forEach((item) => {
        const itemFilter = item.dataset.category;
        const matches = filter === 'all' || itemFilter === filter;

        if (matches) {
          item.classList.remove('hidden');
          item.style.display = visibleCount < this.showCount ? 'block' : 'none';
          visibleCount++;
        } else {
          item.classList.add('hidden');
          item.style.display = 'none';
        }
      });

      this.updateLoadMoreVisibility();
    }

    initLightbox() {
      if (!this.lightbox) return;

      this.imageWrappers.forEach((wrapper, index) => {
        wrapper.addEventListener('click', () => this.openLightbox(index));
        wrapper.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            this.openLightbox(index);
          }
        });
      });

      const closeBtn = this.lightbox.querySelector('.lightbox-close');
      closeBtn?.addEventListener('click', () => this.closeLightbox());
      this.lightbox?.addEventListener('click', (e) => {
        if (e.target === this.lightbox) this.closeLightbox();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.lightbox?.open) {
          this.closeLightbox();
        }
      });
    }

    openLightbox(index) {
      if (!this.lightbox) return;

      const imageWrapper = this.imageWrappers[index];
      const img = imageWrapper?.querySelector('img');

      if (img) {
        const lightboxImg = this.lightbox.querySelector('.lightbox-image');
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        this.lightbox.showModal();

        setTimeout(() => {
          this.lightbox.querySelector('.lightbox-close')?.focus();
        }, 0);
      }
    }

    closeLightbox() {
      if (this.lightbox?.open) {
        this.lightbox.close();
      }
    }

    initLoadMore() {
      this.loadMoreBtn?.addEventListener('click', () => {
        let shown = 0;
        const activeFilter = this.querySelector('[aria-pressed="true"]')?.dataset.filter || 'all';

        this.projectItems.forEach((item) => {
          if (item.style.display === 'none') {
            const itemFilter = item.dataset.category;
            const matches = activeFilter === 'all' || itemFilter === activeFilter;

            if (matches) {
              item.style.display = 'block';
              shown++;
            }
          }
        });

        this.updateLoadMoreVisibility();
      });
    }

    updateLoadMoreVisibility() {
      if (!this.loadMoreBtn) return;

      let hiddenCount = 0;
      const activeFilter = this.querySelector('[aria-pressed="true"]')?.dataset.filter || 'all';

      this.projectItems.forEach((item) => {
        if (item.style.display === 'none') {
          const itemFilter = item.dataset.category;
          const matches = activeFilter === 'all' || itemFilter === activeFilter;
          if (matches) hiddenCount++;
        }
      });

      this.loadMoreBtn.style.display = hiddenCount > 0 ? 'inline-block' : 'none';
    }

    initKeyboard() {
      this.filterButtons.forEach((btn) => {
        btn.setAttribute('role', 'tab');
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Tab') {
          this.filterButtons.forEach((btn) => {
            btn.style.outline = btn.matches(':focus-visible') ? '2px solid #4A90E2' : 'none';
          });
        }
      });
    }
  }

  customElements.define('project-gallery', ProjectGallery);
</script>

