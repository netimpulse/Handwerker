{% comment %}
  News & Insights Section - Craftsman Theme
  Features: Featured article, article cards, category filtering, read time, smooth animations
{% endcomment %}

{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign title_font = section.settings.title_font
  assign title_size = section.settings.title_size
  assign title_bold = section.settings.title_bold
  assign title_weight = '700'
  if title_bold == false
    assign title_weight = '400'
  endif
  assign sh_font = section.settings.subtitle_font
  assign sh_size = section.settings.subtitle_size
-%}

<news-insights-craftsman class="news-insights-wrapper color-{{ section.settings.color_scheme }}">
  <div
    class="news-insights-container"
    style="--title-font:{{ title_font }};--title-size:{{ title_size }}px;--title-weight:{{ title_weight }};--subtitle-font:{{ sh_font }};--subtitle-size:{{ sh_size }}px;"
  >
    <div class="news-header">
      {%- if show_label and label_text != blank -%}
        <span class="section-label">{{ label_text }}</span>
      {%- endif -%}
      <h2 class="news-title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle %}
        <p class="news-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="news-grid">
        <!-- Featured Article (first block) -->
        <div class="featured-article">
          {% assign featured = section.blocks[0] %}

          <div class="featured-image-wrapper">
            {% if featured.settings.image %}
              <img
                src="{{ featured.settings.image | image_url: width: 800 }}"
                alt="{{ featured.settings.title }}"
                class="featured-image"
                loading="lazy"
              >
            {% else %}
              <div class="featured-image-placeholder"></div>
            {% endif %}
            <div class="featured-overlay"></div>
          </div>

          <div class="featured-content">
            <div class="featured-meta">
              <span class="category-tag category-{{ featured.settings.category | downcase | replace: ' ', '-' }}">
                {{ featured.settings.category }}
              </span>
              {%- if featured.settings.date != blank -%}
                <time class="article-date">{{ featured.settings.date | date: "%b %d, %Y" }}</time>
              {%- endif -%}
            </div>

            {%- if featured.settings.title != blank -%}
              <h3 class="featured-title">{{ featured.settings.title }}</h3>
            {%- endif -%}

            {%- if featured.settings.excerpt != blank -%}
              <p class="featured-excerpt">{{ featured.settings.excerpt }}</p>
            {%- endif -%}

            <div class="featured-footer">
              {%- if featured.settings.read_time > 0 -%}
                <span class="read-time">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1"/>
                    <path d="M8 3v5l3 2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                  </svg>
                  {{ featured.settings.read_time }} min read
                </span>
              {%- endif -%}

              {%- if featured.settings.url != blank -%}
                <a href="{{ featured.settings.url }}" class="featured-link">
                  Read Full Article
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>

        <!-- Secondary Articles Grid -->
        {% if section.blocks.size > 1 %}
          <div class="secondary-articles">
            {% for block in section.blocks offset: 1 limit: 3 %}
              <article
                class="article-card fade-in"
                style="animation-delay: {{ forloop.index | times: 0.15 }}s;"
                {{ block.shopify_attributes }}
              >
                <div class="article-image-wrapper">
                  {% if block.settings.image %}
                    <img
                      src="{{ block.settings.image | image_url: width: 400 }}"
                      alt="{{ block.settings.title }}"
                      class="article-image"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="article-image-placeholder"></div>
                  {% endif %}
                  <div class="article-overlay"></div>
                </div>

                <div class="article-content">
                  <div class="article-meta">
                    <span class="category-tag category-{{ block.settings.category | downcase | replace: ' ', '-' }}">
                      {{ block.settings.category }}
                    </span>
                  </div>

                  {%- if block.settings.title != blank -%}
                    <h4 class="article-title">{{ block.settings.title }}</h4>
                  {%- endif -%}

                  {%- if block.settings.excerpt != blank -%}
                    <p class="article-excerpt">{{ block.settings.excerpt | strip_html | truncatewords: 15 }}</p>
                  {%- endif -%}

                  <div class="article-footer">
                    <div class="article-details">
                      {%- if block.settings.date != blank -%}
                        <time class="article-date-small">{{ block.settings.date | date: "%b %d" }}</time>
                      {%- endif -%}
                      {%- if block.settings.read_time > 0 -%}
                        <span class="read-time-small">{{ block.settings.read_time }}m</span>
                      {%- endif -%}
                    </div>

                    <a href="{{ block.settings.url }}" class="article-link" aria-label="Read article: {{ block.settings.title }}">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M5 2L10 7L5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    {% else %}
      <div class="news-placeholder">
        <p>Add articles to display news section</p>
      </div>
    {% endif %}
  </div>
</news-insights-craftsman>

<style>
  #shopify-section-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding }}px {{ section.settings.padding }}px {{ section.settings.padding }}px;
    background-color: rgb(var(--color-background));
  }

  /* ===== SECTION LABEL ===== */
  #shopify-section-{{ section.id }} .section-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgb(var(--color-button));
    background: rgba(var(--color-button), 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .news-header {
    text-align: center;
    margin-bottom: 50px;
  }

  #shopify-section-{{ section.id }} .news-title {
    font-family: var(--title-font, inherit);
    font-size: var(--title-size, 36px);
    font-weight: var(--title-weight, 700);
    color: rgb(var(--color-foreground));
    margin: 0 0 12px 0;
    overflow-wrap: break-word;
  }

  #shopify-section-{{ section.id }} .news-subtitle {
    font-family: var(--subtitle-font, inherit);
    font-size: var(--subtitle-size, 16px);
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
    line-height: 1.6;
  }

  /* Grid Layout */
  #shopify-section-{{ section.id }} .news-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 50px;
  }

  /* Featured Article */
  #shopify-section-{{ section.id }} .featured-article {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .featured-image-wrapper {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(var(--color-foreground), 0.12);
  }

  #shopify-section-{{ section.id }} .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #shopify-section-{{ section.id }} .featured-article:hover .featured-image {
    transform: scale(1.08);
  }

  #shopify-section-{{ section.id }} .featured-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(var(--color-foreground), 0) 0%, rgba(var(--color-foreground), 0.1) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #shopify-section-{{ section.id }} .featured-article:hover .featured-overlay {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .featured-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgb(var(--color-foreground)) 0%, rgba(var(--color-foreground), 0.8) 100%);
  }

  /* Featured Content */
  #shopify-section-{{ section.id }} .featured-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .featured-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .featured-title {
    font-family: inherit;
    font-size: 28px;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0;
    line-height: 1.3;
    transition: color 0.3s ease;
    overflow-wrap: break-word;
  }

  #shopify-section-{{ section.id }} .featured-article:hover .featured-title {
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .featured-excerpt {
    font-family: inherit;
    font-size: 16px;
    color: rgba(var(--color-foreground), 0.6);
    line-height: 1.8;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .featured-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-top: 16px;
    border-top: 2px solid rgba(var(--color-border), 0.2);
  }

  #shopify-section-{{ section.id }} .read-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: inherit;
    font-size: 16px;
    color: rgba(var(--color-foreground), 0.6);
  }

  #shopify-section-{{ section.id }} .featured-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    font-family: inherit;
    font-size: 16px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .featured-link:hover {
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .featured-link svg {
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .featured-link:hover svg {
    transform: translateX(4px);
  }

  /* Secondary Articles */
  #shopify-section-{{ section.id }} .secondary-articles {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .article-card {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: rgb(var(--color-background));
    border: 1px solid rgb(var(--color-border));
    border-radius: 10px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .article-card:hover {
    border-color: rgb(var(--color-button));
    box-shadow: 0 8px 24px rgba(var(--color-button), 0.12);
    transform: translateY(-4px);
  }

  #shopify-section-{{ section.id }} .article-image-wrapper {
    position: relative;
    width: 140px;
    height: 140px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 8px;
  }

  #shopify-section-{{ section.id }} .article-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #shopify-section-{{ section.id }} .article-card:hover .article-image {
    transform: scale(1.1);
  }

  #shopify-section-{{ section.id }} .article-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(var(--color-foreground), 0.1);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .article-card:hover .article-overlay {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .article-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgb(var(--color-foreground)) 0%, rgba(var(--color-foreground), 0.8) 100%);
  }

  /* Article Content */
  #shopify-section-{{ section.id }} .article-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .article-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .article-title {
    font-family: inherit;
    font-size: 16px;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0;
    line-height: 1.4;
    transition: color 0.3s ease;
    overflow-wrap: break-word;
  }

  #shopify-section-{{ section.id }} .article-card:hover .article-title {
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .article-excerpt {
    font-family: inherit;
    font-size: 16px;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
    flex: 1;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .article-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-top: 8px;
    border-top: 1px solid rgba(var(--color-border), 0.2);
  }

  #shopify-section-{{ section.id }} .article-details {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .article-date-small {
    font-family: inherit;
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.6);
  }

  #shopify-section-{{ section.id }} .read-time-small {
    font-family: inherit;
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.6);
  }

  #shopify-section-{{ section.id }} .article-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: rgba(var(--color-foreground), 0.1);
    color: rgb(var(--color-foreground));
    border-radius: 50%;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .article-link:hover {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-button));
    transform: scale(1.1);
  }

  /* Category Tags */
  #shopify-section-{{ section.id }} .category-tag {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 12px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .category-project-updates {
    background: rgba(var(--color-button), 0.1);
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .category-tips-tricks {
    background: rgba(var(--color-link), 0.1);
    color: rgb(var(--color-link));
  }

  #shopify-section-{{ section.id }} .category-industry-news {
    background: rgba(var(--color-foreground), 0.08);
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .category-case-studies {
    background: rgba(var(--color-button), 0.15);
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .category-tag:not(.category-project-updates):not(.category-tips-tricks):not(.category-industry-news):not(.category-case-studies) {
    background: rgba(var(--color-foreground), 0.08);
    color: rgba(var(--color-foreground), 0.7);
  }

  #shopify-section-{{ section.id }} .article-date {
    font-family: inherit;
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.6);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  #shopify-section-{{ section.id }} .news-placeholder {
    text-align: center;
    padding: 80px 20px;
    color: rgba(var(--color-foreground), 0.6);
    font-family: inherit;
  }

  /* Fade-in Animation */
  #shopify-section-{{ section.id }} .fade-in {
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .news-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    #shopify-section-{{ section.id }} .featured-title {
      font-size: 24px;
    }

    #shopify-section-{{ section.id }} .secondary-articles {
      gap: 16px;
    }
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding: 16px;
    }

    #shopify-section-{{ section.id }} .news-title {
      font-size: 24px;
    }

    #shopify-section-{{ section.id }} .news-grid {
      gap: 20px;
    }

    #shopify-section-{{ section.id }} .featured-image-wrapper {
      aspect-ratio: 16 / 9;
    }

    #shopify-section-{{ section.id }} .featured-title {
      font-size: 20px;
    }

    #shopify-section-{{ section.id }} .featured-footer {
      flex-direction: column;
      align-items: flex-start;
      border: none;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .article-card {
      flex-direction: column;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .article-image-wrapper {
      width: 100%;
      height: 200px;
    }

    #shopify-section-{{ section.id }} .article-footer {
      justify-content: space-between;
    }
  }

  @media (max-width: 480px) {
    #shopify-section-{{ section.id }} .news-header {
      margin-bottom: 30px;
    }

    #shopify-section-{{ section.id }} .featured-image-wrapper {
      aspect-ratio: 16 / 10;
    }

    #shopify-section-{{ section.id }} .featured-title {
      font-size: 18px;
    }

    #shopify-section-{{ section.id }} .featured-excerpt {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .article-image-wrapper {
      height: 150px;
    }

    #shopify-section-{{ section.id }} .article-title {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .article-excerpt {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .news-title {
      font-size: 20px;
    }

    #shopify-section-{{ section.id }} .news-subtitle {
      font-size: 16px;
    }
  }
</style>

<script>
  class NewsInsightsCraftsman extends HTMLElement {
    connectedCallback() {
      this.initScrollAnimations();
    }

    initScrollAnimations() {
      const container = this.querySelector(`#shopify-section-${this.getSessionId()}`);
      if (!container) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });

      container.querySelectorAll('.article-card').forEach(card => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(card);
      });
    }

    getSessionId() {
      const id = this.querySelector('[id^="shopify-section-"]')?.id;
      return id ? id.replace('shopify-section-', '') : '';
    }
  }

  customElements.define('news-insights-craftsman', NewsInsightsCraftsman);
</script>

{% schema %}
{
  "name": "News & Insights",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show section label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "News"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "News & Insights"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Stay updated with the latest"
    },
    {
      "type": "header",
      "content": "Title Typography"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Title font",
      "options": [
        { "value": "system-ui, sans-serif", "label": "System" },
        { "value": "inherit", "label": "Inherit" }
      ],
      "default": "system-ui, sans-serif"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size (px)",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "title_bold",
      "label": "Title bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subtitle Typography"
    },
    {
      "type": "select",
      "id": "subtitle_font",
      "label": "Subtitle font",
      "options": [
        { "value": "system-ui, sans-serif", "label": "System" },
        { "value": "inherit", "label": "Inherit" }
      ],
      "default": "system-ui, sans-serif"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle Size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1300
    },
    {
      "type": "range",
